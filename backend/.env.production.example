APP_NAME=campus_secondhand_platform
API_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_SECONDS=604800
DB_BACKEND=mysql
MYSQL_ADDRESS=replace-with-cloudrun-mysql-address
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=replace-with-cloudrun-mysql-password
MYSQL_DATABASE=flask_demo
INIT_TOKEN=replace-with-init-token
DEV_TEST_LOGIN_ENABLED=0
CORS_ORIGINS=https://servicewechat.com
UPLOAD_FOLDER=/var/www/campus_secondhand/uploads
PAYMENT_MODE=mock
AI_MODE=qwen
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
AI_TIMEOUT_SECONDS=30
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
WECHAT_AUTH_MODE=wechat
WECHAT_APPID=replace-with-wechat-appid
WECHAT_SECRET=replace-with-wechat-secret
FLASK_HOST=0.0.0.0
FLASK_PORT=80
FLASK_DEBUG=0
ORDER_PAYMENT_TIMEOUT_MINUTES=30
ORDER_AUTO_RECEIVE_DAYS=7
REFUND_SELLER_TIMEOUT_HOURS=48
