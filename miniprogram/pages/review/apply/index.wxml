<view class="page">
  <view class="panel">
    <view class="title">这次交易怎么样？</view>
    <view class="stars">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="{{item <= rating ? 'active' : ''}}" data-value="{{item}}" bindtap="chooseRating">★</text>
    </view>
    <textarea value="{{content}}" bindinput="onInput" maxlength="300" placeholder="写下真实的交易体验，帮助更多同学"></textarea>
    <label class="anonymous"><switch checked="{{anonymous}}" bindchange="toggleAnonymous" color="#1f7a68" />匿名评价</label>
    <button class="primary-btn" bindtap="submit">发布评价</button>
  </view>
</view>
