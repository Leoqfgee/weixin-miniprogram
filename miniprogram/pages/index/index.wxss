.home-page{padding:28rpx 18rpx 118rpx;background:#fff}.brand-block{padding:12rpx 0 22rpx}.brand-title{color:#0b9f59;font-size:40rpx;font-weight:900}.brand-title text{color:#18c86d}.search-panel{display:flex;align-items:center;gap:10rpx;height:62rpx;padding:0 6rpx 0 18rpx;background:#fff;border:3rpx solid #10a65d;border-radius:10rpx}.search-icon{color:#a4adb7;font-size:26rpx}.search-panel input{flex:1;height:58rpx;min-width:0;padding:0 8rpx;background:transparent}.search-btn{width:104rpx;height:52rpx;line-height:52rpx;margin:0;padding:0;color:#fff;background:#14b96b;border:0;border-radius:10rpx;font-size:23rpx}.category-panel{display:grid;grid-template-columns:repeat(5,1fr);gap:10rpx;margin-top:22rpx;padding-bottom:8rpx}.category-item{margin:0;padding:0;color:#1f2933;background:transparent;border:0;font-size:22rpx}.category-item.active{color:#0f8f4f;font-weight:800}.category-item.active .category-icon{color:#fff;background:#16b85e}.category-icon{display:flex;align-items:center;justify-content:center;width:62rpx;height:62rpx;margin:0 auto 9rpx;color:#0ea45e;background:#e7f8ee;border-radius:18rpx;font-size:26rpx;font-weight:900}.mode-panel{display:flex;align-items:center;justify-content:space-between;margin-top:18rpx;padding:8rpx 0}.mode-tabs{display:flex;gap:54rpx}.mode-tab{position:relative;height:58rpx;line-height:58rpx;margin:0;padding:0;color:#535f68;background:transparent;border:0;font-size:26rpx;font-weight:700}.mode-tab.active{color:#0ca05a}.mode-tab.active::after{content:"";position:absolute;left:10rpx;right:10rpx;bottom:0;height:6rpx;border-radius:999rpx;background:#10b665}.filter-line{color:#6b747e;font-size:23rpx}.mode-loading{padding:14rpx 0;color:#16a45a;text-align:center}.product-list{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16rpx;margin-top:12rpx}
