.home-sticky { position: sticky; top: 0; z-index: 40; margin: 0 -22rpx 18rpx; padding: 18rpx 22rpx 14rpx; background: rgba(245,248,246,.98); backdrop-filter: blur(12rpx); box-shadow: 0 8rpx 18rpx rgba(31,41,51,.04); }
.home-page {
  padding: 0 22rpx 120rpx;
  background: #f5f8f6;
}

.search-panel {
  display: flex;
  align-items: center;
  height: 76rpx;
  padding: 0 8rpx 0 22rpx;
  background: #ffffff;
  border: 2rpx solid #14ad65;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(17, 157, 88, 0.10);
}

.search-icon { color: #9aa5ad; font-size: 28rpx; }
.search-panel input { flex: 1; min-width: 0; height: 72rpx; padding: 0 18rpx; background: transparent; border: 0; }
.search-btn { flex: 0 0 148rpx; height: 60rpx; line-height: 60rpx; padding: 0; color: #fff; background: #12ad62; border-radius: 999rpx; font-size: 25rpx; font-weight: 800; }
.search-btn::after { border: 0; }

.category-scroll { margin-top: 22rpx; white-space: nowrap; }
.category-row { display: inline-flex; gap: 18rpx; padding: 2rpx 2rpx 10rpx; }
.category-item { width: 124rpx; text-align: center; color: #26343f; font-size: 22rpx; }
.category-icon { display: flex; align-items: center; justify-content: center; width: 82rpx; height: 82rpx; margin: 0 auto 10rpx; border-radius: 28rpx; background: #ffffff; box-shadow: 0 8rpx 22rpx rgba(31,41,51,.06); }
.category-icon image { width: 54rpx; height: 54rpx; }
.category-item.active .category-icon { background: #e9fbf2; box-shadow: inset 0 0 0 2rpx #19b56d; }
.category-item.active { color: #0d9855; font-weight: 800; }

.mode-panel { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin: 18rpx 0 20rpx; }
.mode-tabs { flex: 1; display: flex; padding: 6rpx; background: #ffffff; border-radius: 999rpx; box-shadow: 0 8rpx 22rpx rgba(31,41,51,.06); }
.mode-tab { flex: 1; height: 58rpx; line-height: 58rpx; text-align: center; color: #697386; border-radius: 999rpx; font-size: 25rpx; }
.mode-tab.active { color: #ffffff; background: #16b86b; font-weight: 900; box-shadow: 0 8rpx 18rpx rgba(22,184,107,.20); }
.filter-line { flex: none; display: flex; align-items: center; gap: 8rpx; color: #687380; font-size: 24rpx; }
.filter-icon { width: 22rpx; height: 22rpx; border: 3rpx solid #687380; border-top: 0; border-left: 0; transform: rotate(45deg); }
.mode-loading { padding: 30rpx 0; color: #8a94a1; text-align: center; }
.product-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
