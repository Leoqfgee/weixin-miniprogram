.home-page {
  padding-bottom: 44rpx;
}

.brand-block {
  padding: 12rpx 6rpx 22rpx;
}

.brand-title {
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 900;
}

.brand-title text {
  color: #16b85e;
  margin-left: 6rpx;
}

.search-panel {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 86rpx;
  padding: 0 10rpx 0 22rpx;
  background: #ffffff;
  border: 3rpx solid #16b85e;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(22, 184, 94, 0.10);
}

.search-icon {
  color: #7a8491;
  font-size: 42rpx;
}

.search-panel input {
  flex: 1;
  height: 78rpx;
  min-width: 0;
  padding: 0 12rpx;
  border: 0;
  background: transparent;
}

.search-btn {
  width: 124rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
}

.category-panel,
.mode-panel {
  margin-top: 22rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 51, 0.06);
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 18rpx 8rpx;
  padding: 24rpx 14rpx;
}

.category-item {
  margin: 0;
  padding: 0;
  color: #1f2933;
  background: transparent;
  border: 0;
  font-size: 23rpx;
}

.category-item.active {
  color: #0f8f4f;
  font-weight: 800;
}

.category-item.active .category-icon {
  color: #ffffff;
  background: #16b85e;
}

.category-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 10rpx;
  color: #16a45a;
  background: #eaf8ef;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.category-icon.more {
  color: #7a8491;
  background: #f1f3f1;
}

.mode-panel {
  padding: 14rpx;
}

.mode-tabs {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx;
  background: #f3f6f4;
  border-radius: 999rpx;
}

.mode-tab {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0;
  color: #687380;
  background: transparent;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #20bd5f, #11924f);
  box-shadow: 0 10rpx 22rpx rgba(22, 184, 94, 0.22);
}

.mode-loading {
  padding: 14rpx 4rpx 2rpx;
  color: #16a45a;
  font-size: 24rpx;
  text-align: center;
}

.product-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}
