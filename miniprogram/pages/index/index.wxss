.home-page {
  padding-bottom: 44rpx;
}

.brand-block {
  padding: 12rpx 6rpx 22rpx;
}

.brand-title {
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 900;
}

.brand-title text {
  color: #16b85e;
  margin-left: 6rpx;
}

.brand-sub {
  margin-top: 6rpx;
  color: #7a8491;
  font-size: 26rpx;
}

.search-panel {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 86rpx;
  padding: 0 10rpx 0 22rpx;
  background: #ffffff;
  border: 3rpx solid #16b85e;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(22, 184, 94, 0.10);
}

.search-icon {
  color: #7a8491;
  font-size: 42rpx;
}

.search-panel input {
  flex: 1;
  height: 78rpx;
  min-width: 0;
  padding: 0 12rpx;
  border: 0;
  background: transparent;
}

.search-btn {
  width: 124rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
}

.hero-card {
  position: relative;
  display: flex;
  justify-content: space-between;
  min-height: 190rpx;
  margin-top: 24rpx;
  padding: 34rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f3fbf4 0%, #e5f7e8 100%);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(21, 99, 69, 0.09);
}

.hero-title {
  color: #1f2933;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 900;
}

.hero-sub {
  margin-top: 14rpx;
  color: #5e6874;
  font-size: 25rpx;
}

.hero-btn {
  width: 136rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 26rpx 0 0;
  color: #fff;
  background: #20bd5f;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.hero-visual {
  position: absolute;
  right: 24rpx;
  bottom: 14rpx;
  width: 190rpx;
  height: 150rpx;
}

.bag {
  position: absolute;
  right: 20rpx;
  bottom: 0;
  width: 104rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #27c96b, #0f9f55);
  border-radius: 24rpx 24rpx 18rpx 18rpx;
}

.bag::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: -22rpx;
  width: 48rpx;
  height: 44rpx;
  border: 10rpx solid #21b85e;
  border-bottom: 0;
  border-radius: 40rpx 40rpx 0 0;
}

.book {
  position: absolute;
  left: 12rpx;
  bottom: 10rpx;
  width: 78rpx;
  height: 18rpx;
  background: #ffffff;
  border-radius: 8rpx;
}

.book.one {
  bottom: 38rpx;
  background: #dff4e5;
}

.book.two {
  bottom: 66rpx;
  background: #fff7d6;
}

.category-panel,
.mode-panel {
  margin-top: 22rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 51, 0.06);
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx 8rpx;
  padding: 24rpx 14rpx;
}

.category-item {
  margin: 0;
  padding: 0;
  color: #1f2933;
  background: transparent;
  border: 0;
  font-size: 23rpx;
}

.category-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 10rpx;
  color: #16a45a;
  background: #eaf8ef;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.category-icon.more {
  color: #7a8491;
  background: #f1f3f1;
}

.mode-panel {
  padding: 14rpx;
}

.mode-tabs {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx;
  background: #f3f6f4;
  border-radius: 999rpx;
}

.mode-tab {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0;
  color: #687380;
  background: transparent;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.mode-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #20bd5f, #11924f);
  box-shadow: 0 10rpx 22rpx rgba(22, 184, 94, 0.22);
}

.mode-loading {
  padding: 14rpx 4rpx 2rpx;
  color: #16a45a;
  font-size: 24rpx;
  text-align: center;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 22rpx;
}
