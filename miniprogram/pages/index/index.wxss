.home-page {
  padding-bottom: 36rpx;
}

.market-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 32rpx 28rpx;
  background: #1f7a68;
  border-radius: 8rpx;
  color: #fff;
  box-shadow: 0 14rpx 34rpx rgba(31, 122, 104, 0.18);
}

.header-main {
  flex: 1;
  min-width: 0;
}

.location {
  display: inline-block;
  padding: 8rpx 14rpx;
  color: #ffe0b5;
  background: rgba(255, 255, 255, 0.13);
  border-radius: 8rpx;
  font-size: 23rpx;
}

.headline {
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 900;
}

.subline {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
  line-height: 1.45;
}

.refresh-btn {
  flex: none;
  width: 108rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0;
  color: #1f7a68;
  background: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.search-panel {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  background: #fff;
  border: 1rpx solid #ebe2d6;
  border-radius: 8rpx;
}

.search-icon {
  width: 42rpx;
  text-align: center;
  color: #77808b;
  font-size: 32rpx;
}

.search-panel input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 16rpx;
  background: #f7f4ee;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.search-btn {
  flex: none;
  width: 118rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  font-size: 26rpx;
}

.feature-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.feature-card {
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #ebe2d6;
  border-radius: 8rpx;
}

.feature-title {
  color: #17202a;
  font-size: 28rpx;
  font-weight: 800;
}

.feature-desc {
  margin-top: 6rpx;
  color: #77808b;
  font-size: 23rpx;
}

.category-panel {
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #ebe2d6;
  border-radius: 8rpx;
}

.section-head,
.board-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-head {
  margin-bottom: 14rpx;
  color: #17202a;
  font-weight: 800;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.category-chip {
  height: 60rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 10rpx;
  color: #35414d;
  background: #f7f4ee;
  border: 1rpx solid #eadfce;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.small-title {
  font-size: 32rpx;
}

.cart-link {
  width: 108rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0;
  color: #e0522d;
  background: #fff3ed;
  border: 1rpx solid #ffd2bf;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.product-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
