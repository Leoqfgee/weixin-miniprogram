<view class="page home-page">
  <view class="brand-block">
    <view class="brand-title">校园<text>二手</text></view>
  </view>

  <view class="search-panel">
    <text class="search-icon">搜</text>
    <input value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索商品名称 / 分类 / 关键词" confirm-type="search" bindconfirm="goSearch" />
    <button class="primary-btn search-btn" bindtap="goSearch">搜索</button>
  </view>

  <view class="category-panel" wx:if="{{categories.length}}">
    <view class="category-grid">
      <button wx:for="{{categories}}" wx:key="code" class="category-item {{activeCategory === item.code ? 'active' : ''}}" data-code="{{item.code}}" bindtap="goCategory">
        <view class="category-icon">{{item.short_name}}</view>
        <text>{{item.name}}</text>
      </button>
    </view>
  </view>

  <view class="mode-panel">
    <view class="mode-tabs">
      <button wx:for="{{modeTabs}}" wx:key="value" class="mode-tab {{activeMode === item.value ? 'active' : ''}}" data-mode="{{item.value}}" bindtap="switchMode">
        {{item.label}}
      </button>
    </view>
    <view class="filter-line" bindtap="openFilter">筛选</view>
    <view wx:if="{{loading}}" class="mode-loading">加载中...</view>
  </view>

  <view wx:if="{{products.length}}" class="product-list">
    <product-card wx:for="{{products}}" wx:key="id" product="{{item}}" layout="grid"></product-card>
  </view>

  <empty-state wx:else title="{{emptyTitle}}"></empty-state>
</view>
