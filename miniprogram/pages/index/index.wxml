<view class="page home-page">
  <view class="brand-block">
    <view class="brand-title">校园<text>二手</text></view>
    <view class="brand-sub">让闲置流转，让校园更美好</view>
  </view>

  <view class="search-panel">
    <text class="search-icon">⌕</text>
    <input value="{{keyword}}" bindinput="onKeywordInput" placeholder="搜索商品名称 / 分类 / 关键词" confirm-type="search" bindconfirm="goSearch" />
    <button class="primary-btn search-btn" bindtap="goSearch">搜索</button>
  </view>

  <view class="hero-card">
    <view>
      <view class="hero-title">闲置不闲置 · 校园更有爱</view>
      <view class="hero-sub">校内面交更安全，低价好物在身边</view>
      <button class="hero-btn" bindtap="goSearch">去逛逛 ›</button>
    </view>
    <view class="hero-visual">
      <view class="bag"></view>
      <view class="book one"></view>
      <view class="book two"></view>
    </view>
  </view>

  <view class="category-panel" wx:if="{{categories.length}}">
    <view class="category-grid">
      <button wx:for="{{categories}}" wx:key="id" class="category-item" data-id="{{item.id}}" bindtap="goCategory">
        <view class="category-icon">{{item.short_name}}</view>
        <text>{{item.name}}</text>
      </button>
      <button class="category-item" bindtap="goSearch">
        <view class="category-icon more">••</view>
        <text>全部分类</text>
      </button>
    </view>
  </view>

  <view class="filter-bar">
    <view class="filter active">全部</view>
    <view class="filter">距离⌄</view>
    <view class="filter">价格⌄</view>
    <view class="filter active-soft">最新发布</view>
    <view class="filter right" bindtap="goSearch">筛选</view>
  </view>

  <view wx:if="{{products.length}}" class="product-list">
    <product-card wx:for="{{products}}" wx:key="id" product="{{item}}"></product-card>
  </view>

  <empty-state wx:else title="暂无在售商品" description="换个关键词试试，或稍后刷新"></empty-state>
</view>
