.product-page{padding:16rpx 20rpx 150rpx;background:#fff}.cover-shell{position:relative;overflow:hidden;border-radius:12rpx}.cover-swiper,.cover-wrap{width:100%;height:386rpx;background:#edf3ee}.placeholder{position:relative;background:linear-gradient(145deg,#dff6e8 0%,#70d99a 52%,#11924f 100%)}.cover-title{position:absolute;left:34rpx;right:34rpx;bottom:42rpx;color:#fff;font-size:56rpx;line-height:1.15;font-weight:900}.image-count{position:absolute;right:20rpx;bottom:18rpx;padding:6rpx 14rpx;color:#fff;background:rgba(31,41,51,.48);border-radius:999rpx;font-size:23rpx}.panel{margin-top:18rpx;padding:24rpx;background:#fff;border:1rpx solid #e8ece8;border-radius:14rpx;box-shadow:0 10rpx 24rpx rgba(31,41,51,.05)}.title-row{display:flex;align-items:flex-start;gap:18rpx}.title{flex:1;min-width:0;color:#1f2933;font-size:32rpx;line-height:1.35;font-weight:900}.mini-actions{display:flex;gap:10rpx}.mini-actions button{width:76rpx;height:58rpx;line-height:58rpx;margin:0;padding:0;color:#11924f;background:#eaf8ef;border:0;border-radius:12rpx;font-size:22rpx}.mini-actions .active{color:#fff;background:#f04438}.price-row{display:flex;align-items:center;gap:18rpx;margin-top:18rpx}.price{color:#09a85e;font-size:44rpx;font-weight:900}.status{padding:6rpx 14rpx;color:#fff;background:#16b85e;border-radius:999rpx;font-size:22rpx}.sub-desc{margin-top:10rpx;color:#5e6874;line-height:1.5}.metric-row{display:grid;grid-template-columns:repeat(3,1fr);margin-top:20rpx;padding:18rpx 0;color:#6b7480;text-align:center;border:1rpx solid #e8ece8;border-radius:18rpx}.block-title{color:#1f2933;font-size:30rpx;font-weight:900}.desc{display:-webkit-box;margin-top:18rpx;color:#334155;line-height:1.75;overflow:hidden;-webkit-line-clamp:4;-webkit-box-orient:vertical}.desc.expanded{display:block}.expand{margin-top:16rpx;color:#16a45a;text-align:center}.seller-card{display:flex;align-items:center;gap:18rpx}.seller-avatar{width:84rpx;height:84rpx;border-radius:50%;background:#dfe5ea;flex:none}.seller-main{flex:1;min-width:0}.seller-name{color:#1f2933;font-size:32rpx;font-weight:900}.chevron{color:#8a949f;font-size:48rpx}.trade-row{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;color:#202733;font-size:25rpx}.trade-row text{color:#697581}.trade-row view{text-align:right}.recommend-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18rpx;margin-top:18rpx}.bottom-bar{position:fixed;z-index:8;left:0;right:0;bottom:0;display:flex;gap:16rpx;padding:18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.96);box-shadow:0 -8rpx 24rpx rgba(20,33,45,.08)}.bottom-bar button{flex:1;min-width:0;height:84rpx;line-height:84rpx}.collect-btn{flex:0 0 120rpx;margin:0;padding:0;color:#1f2933;background:#fff;border:1rpx solid #e8ece8;font-size:24rpx}
