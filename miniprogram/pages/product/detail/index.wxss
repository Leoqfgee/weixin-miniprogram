.product-page {
  padding: 18rpx 20rpx 150rpx;
}

.cover-shell {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
}

.cover-swiper,
.cover-wrap {
  width: 100%;
  height: 520rpx;
  background: #edf3ee;
}

.placeholder {
  position: relative;
  background: linear-gradient(145deg, #dff6e8 0%, #70d99a 52%, #11924f 100%);
}

.cover-tag,
.image-count,
.preview-chip,
.album-chip {
  position: absolute;
  z-index: 2;
  padding: 8rpx 18rpx;
  color: #ffffff;
  background: rgba(31, 41, 51, 0.48);
  border-radius: 999rpx;
  font-size: 23rpx;
}

.cover-tag {
  left: 24rpx;
  top: 24rpx;
}

.cover-title {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 42rpx;
  color: #ffffff;
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 900;
}

.image-count {
  left: 24rpx;
  bottom: 24rpx;
}

.preview-chip {
  right: 24rpx;
  top: 24rpx;
  background: rgba(31, 41, 51, 0.36);
}

.album-chip {
  right: 24rpx;
  bottom: 24rpx;
}

.summary-panel {
  margin-top: -18rpx;
  position: relative;
  z-index: 3;
  border-radius: 28rpx;
}

.summary-head {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.summary-head .title {
  flex: 1;
  min-width: 0;
  line-height: 1.25;
}

.price-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.price {
  color: #f04438;
  font-size: 54rpx;
  font-weight: 900;
}

.share-btn {
  width: 116rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0;
  color: #11924f;
  background: #eaf8ef;
  border: 0;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.sub-desc {
  margin-top: 10rpx;
  color: #5e6874;
  line-height: 1.5;
}

.meta-line,
.seller-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.meta-line text,
.seller-tags text {
  padding: 7rpx 16rpx;
  color: #11924f;
  background: #eaf8ef;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.metric-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 22rpx;
  padding: 18rpx 0;
  color: #6b7480;
  text-align: center;
  border: 1rpx solid #e8ece8;
  border-radius: 18rpx;
}

.seller-card,
.detail-block,
.recommend-panel {
  margin-top: 20rpx;
}

.seller-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-color: #bfeccc;
}

.seller-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #dfe5ea;
  flex: none;
}

.seller-main {
  flex: 1;
  min-width: 0;
}

.seller-name {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 900;
}

.chevron {
  color: #8a949f;
  font-size: 48rpx;
}

.block-title {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 900;
}

.desc {
  display: -webkit-box;
  margin-top: 18rpx;
  color: #334155;
  line-height: 1.75;
  overflow: hidden;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.desc.expanded {
  display: block;
}

.expand {
  margin-top: 16rpx;
  color: #7a8491;
  text-align: center;
}

.recommend-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.state-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  color: #8a5a15;
  background: #fff7e6;
  border-radius: 18rpx;
  font-size: 24rpx;
}

.bottom-bar {
  position: fixed;
  z-index: 8;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
}

.bottom-bar button {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  line-height: 84rpx;
}

.collect-btn {
  flex: 0 0 112rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  padding: 0;
  color: #1f2933;
  background: #ffffff;
  border: 0;
  font-size: 24rpx;
}
