.product-page {
  padding-bottom: 130rpx;
}

.cover-wrap {
  width: 100%;
  height: 520rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #eef1f4;
}

.placeholder {
  position: relative;
  background: linear-gradient(145deg, #f7c66b 0%, #ef8b58 54%, #1f7a68 100%);
}

.cover-tag {
  position: absolute;
  left: 22rpx;
  top: 22rpx;
  padding: 8rpx 14rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.22);
  border-radius: 8rpx;
  font-size: 24rpx;
}

.cover-title {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 34rpx;
  color: #fff;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
}

.summary-panel,
.seller-card,
.detail-block {
  margin-top: 18rpx;
}

.row,
.seller-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  color: #e0522d;
  font-size: 48rpx;
  font-weight: 900;
}

.meta-line {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-line text {
  padding: 8rpx 14rpx;
  color: #56616d;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 23rpx;
}

.seller-card {
  gap: 18rpx;
}

.seller-avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #dfe5ea;
  flex: none;
}

.seller-main {
  flex: 1;
  min-width: 0;
}

.seller-name {
  color: #17202a;
  font-size: 29rpx;
  font-weight: 800;
}

.chevron {
  color: #98a2ae;
  font-size: 42rpx;
}

.block-title {
  color: #17202a;
  font-size: 30rpx;
  font-weight: 800;
}

.desc {
  margin-top: 14rpx;
  color: #334e68;
  line-height: 1.75;
  font-size: 27rpx;
}

.state-tip {
  margin-top: 16rpx;
  padding: 16rpx;
  color: #815319;
  background: #fff6e7;
  border-left: 6rpx solid #d89c3c;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.bottom-bar {
  position: fixed;
  z-index: 8;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 14rpx;
  padding: 16rpx 24rpx 22rpx;
  background: #fff;
  border-top: 1rpx solid #e6ebf1;
}

.bottom-bar button {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  line-height: 78rpx;
  margin: 0;
  padding: 0;
  font-size: 25rpx;
}

.danger {
  color: #a61b1b;
  border-color: #a61b1b;
}
