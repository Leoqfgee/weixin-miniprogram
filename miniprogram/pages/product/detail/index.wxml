<view class="page product-page">
  <view wx:if="{{product}}" class="detail-shell">
    <view class="cover-shell"><swiper wx:if="{{gallery.length}}" class="cover-swiper" current="{{currentImage}}" bindchange="onImageChange"><swiper-item wx:for="{{gallery}}" wx:key="*this"><image class="cover-wrap" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="previewGallery" binderror="onGalleryImageError"></image></swiper-item></swiper><view wx:else class="cover-wrap placeholder"><view class="cover-title">{{coverText}}</view></view><view class="image-count">{{currentImage + 1}}/{{gallery.length || 1}}</view></view>
    <view class="summary-panel panel"><view class="title-row"><view class="title">{{product.title}}</view><view class="mini-actions"><button open-type="share">分享</button><button class="{{product.is_favorited ? 'active' : ''}}" bindtap="toggleFavorite">{{product.is_favorited ? '已藏' : '收藏'}}</button></view></view><view class="price-row"><text class="price">{{priceText}}</text><text class="status">{{statusText}}</text></view><view class="sub-desc">{{conditionText}} · {{product.description}}</view><view class="metric-row"><view>浏览 {{product.view_text}}</view><view>库存 {{product.stock_text}}</view><view>收藏 {{product.favorite_text}}</view></view></view>
    <view class="panel detail-block"><view class="block-title">商品描述</view><view class="desc {{descExpanded ? 'expanded' : ''}}">{{product.description}}</view><view class="expand" bindtap="toggleDescription">{{descExpanded ? '收起' : '展开'}} ›</view></view>
    <view class="panel seller-card" bindtap="goSellerProfile"><image class="seller-avatar" src="{{product.seller.avatar || product.seller.avatar_url || '/assets/tabbar/mine.png'}}" mode="aspectFill" binderror="onSellerAvatarError"></image><view class="seller-main"><view class="seller-name">{{product.seller.nickname}}</view><view class="muted">{{product.seller.campus}} · 信用分 {{product.seller.credit_score || 100}}</view></view><text class="chevron">›</text></view>
    <view class="panel trade-card"><view class="block-title">交易信息</view><view class="trade-row"><text>交易方式</text><view>{{product.delivery_text}}</view></view><view class="trade-row"><text>所在校区</text><view>{{product.campus_text}}</view></view><view class="trade-row"><text>商品分类</text><view>{{product.category_text}}</view></view></view>
    <view wx:if="{{recommendations.length}}" class="recommend-panel panel"><view class="block-title">猜你喜欢</view><view class="recommend-grid"><product-card wx:for="{{recommendations}}" wx:key="id" product="{{item}}" layout="grid"></product-card></view></view>
    <view class="bottom-bar"><button wx:if="{{product.allowed_actions.can_buy}}" class="collect-btn" bindtap="toggleFavorite">{{product.is_favorited ? '已收藏' : '收藏'}}</button><button wx:if="{{product.allowed_actions.can_buy}}" class="ghost-btn" bindtap="contactSeller">联系卖家</button><button wx:if="{{product.allowed_actions.can_buy}}" class="primary-btn" bindtap="buyNow">立即购买</button><button wx:if="{{product.allowed_actions.can_edit}}" class="ghost-btn" bindtap="editProduct">编辑</button><button wx:if="{{product.allowed_actions.can_off_shelf || product.allowed_actions.can_force_off_shelf}}" class="ghost-btn danger" bindtap="offShelf">下架</button><button wx:if="{{product.allowed_actions.can_republish}}" class="primary-btn" bindtap="republish">重新发布</button><button wx:if="{{product.allowed_actions.can_delete}}" class="ghost-btn danger" bindtap="deleteProduct">删除</button></view>
  </view>
  <view wx:else class="panel muted">正在加载商品信息...</view>
</view>
