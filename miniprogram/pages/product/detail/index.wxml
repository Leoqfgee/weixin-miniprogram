<view class="page product-page">
<view wx:if="{{product}}" class="detail-shell">
    <view class="cover-shell">
      <swiper wx:if="{{gallery.length}}" class="cover-swiper" current="{{currentImage}}" bindchange="onImageChange">
        <swiper-item wx:for="{{gallery}}" wx:key="*this">
          <image class="cover-wrap" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="previewGallery" binderror="onGalleryImageError"></image>
        </swiper-item>
      </swiper>
      <view wx:else class="cover-wrap placeholder"><view class="cover-tag">{{conditionText}}</view><view class="cover-title">{{coverText}}</view></view>
      <view class="image-count">{{currentImage + 1}}/{{gallery.length || 1}}</view>
      <view wx:if="{{gallery.length}}" class="preview-chip">点击查看大图</view>
      <view wx:if="{{gallery.length > 1}}" class="album-chip">图集</view>
    </view>

    <view class="summary-panel panel">
      <view class="summary-head">
        <view class="title">{{product.display_title}}</view>
        <status-badge status="{{product.status}}"></status-badge>
      </view>
      <view class="price-line">
        <text class="price">{{product.display_price}}</text>
        <view class="summary-actions">
          <button class="mini-action-btn" open-type="share">
            <image class="mini-action-icon" src="/assets/icons/action-share.png" mode="aspectFit"></image>
            <text>分享</text>
          </button>
          <button class="mini-action-btn" bindtap="toggleFavorite">
            <image class="mini-action-icon" src="{{product.is_favorited ? '/assets/icons/action-heart-active.png' : '/assets/icons/action-heart.png'}}" mode="aspectFit"></image>
            <text>{{product.is_favorited ? '已收藏' : '收藏'}}</text>
          </button>
          <button wx:if="{{product.allowed_actions.can_report}}" class="mini-action-btn" bindtap="reportProduct">
            <text>举报</text>
          </button>
        </view>
      </view>
      <view class="sub-desc">{{conditionText}}｜{{product.description || '校内好物，欢迎咨询'}}</view>
      <view class="meta-line">
        <text>校内面交</text>
        <text wx:if="{{product.display_category}}">{{product.display_category}}</text>
        <text>{{product.display_campus}}</text>
      </view>
      <view class="metric-row">
        <view>浏览 {{product.display_views}}</view>
        <view>库存 {{product.display_stock}}</view>
        <view>收藏 {{product.display_favorites}}</view>
      </view>
      <view wx:if="{{product.status === 'locked'}}" class="state-tip">买家已下单，交易完成或取消前暂不可再次购买。</view>
      <view wx:if="{{product.status === 'sold'}}" class="state-tip">商品已卖出，可查看历史订单。</view>
      <view wx:if="{{product.status === 'off_shelf'}}" class="state-tip">商品已下架，买家不能继续购买。</view>
    </view>

    <view class="seller-card panel" bindtap="goSellerProfile">
      <image class="seller-avatar" src="{{product.seller.avatar || product.seller.avatar_url || '/assets/tabbar/mine.png'}}" mode="aspectFill" binderror="onSellerAvatarError"></image>
      <view class="seller-main">
        <view class="seller-name">{{product.seller.nickname || '校园同学'}}</view>
        <view class="muted">{{product.seller.display_campus}}</view>
      </view>
      <text class="chevron">›</text>
    </view>

    <view class="trade-card panel">
      <view class="block-title">交易信息</view>
      <view class="trade-row"><text>交易方式</text><view>{{product.delivery_options && product.delivery_options.length ? '校内面交 / 快递' : '校内面交'}}</view></view>
      <view class="trade-row"><text>所在校区</text><view>{{product.display_campus}}</view></view>
      <view class="trade-row"><text>商品分类</text><view>{{product.category_name || '其他'}}</view></view>
    </view>

    <view class="detail-block panel">
      <view class="block-title">商品描述</view>
      <view class="desc {{descExpanded ? 'expanded' : ''}}">{{product.description || '卖家暂未填写描述'}}</view>
      <view class="expand" bindtap="toggleDescription">{{descExpanded ? '收起' : '展开'}}⌄</view>
    </view>

    <view wx:if="{{recommendations.length}}" class="recommend-panel panel">
      <view class="block-title">猜你喜欢</view>
      <view class="recommend-grid">
        <product-card wx:for="{{recommendations}}" wx:key="id" product="{{item}}" layout="grid"></product-card>
      </view>
    </view>

    <view class="actions bottom-bar">
      <button wx:if="{{product.allowed_actions.can_buy}}" class="collect-btn" bindtap="toggleFavorite">
        <image class="bar-action-icon" src="{{product.is_favorited ? '/assets/icons/action-heart-active.png' : '/assets/icons/action-heart.png'}}" mode="aspectFit"></image>
        <text class="bar-action-text">{{product.is_favorited ? '已收藏' : '收藏'}}</text>
      </button>
      <button wx:if="{{product.allowed_actions.can_buy}}" class="ghost-btn" bindtap="contactSeller">联系卖家</button>
      <button wx:if="{{product.allowed_actions.can_buy}}" class="primary-btn" bindtap="buyNow">立即购买</button>
      <button wx:if="{{product.allowed_actions.can_edit}}" class="ghost-btn" bindtap="editProduct">编辑</button>
      <button wx:if="{{product.allowed_actions.can_off_shelf || product.allowed_actions.can_force_off_shelf}}" class="ghost-btn danger" bindtap="offShelf">下架</button>
      <button wx:if="{{product.allowed_actions.can_republish}}" class="primary-btn" bindtap="republish">重新发布</button>
      <button wx:if="{{product.allowed_actions.can_delete}}" class="ghost-btn danger" bindtap="deleteProduct">删除</button>
    </view>
  </view>
  <view wx:else class="panel muted">正在加载商品信息...</view>
</view>
