.login-page {
  padding: 0 0 40rpx;
  background: #f6fbf8;
}

.login-hero {
  position: relative;
  height: 360rpx;
  padding-top: 92rpx;
  overflow: hidden;
  text-align: center;
  background: linear-gradient(180deg, #e9fbf1 0%, #ffffff 100%);
}

.campus-sky {
  position: absolute;
  left: -40rpx;
  right: -40rpx;
  bottom: 0;
  height: 150rpx;
  background: radial-gradient(circle at 18% 72%, rgba(24, 184, 108, 0.18) 0 28rpx, transparent 30rpx),
    radial-gradient(circle at 84% 70%, rgba(24, 184, 108, 0.16) 0 34rpx, transparent 36rpx),
    linear-gradient(180deg, transparent 0, rgba(16, 166, 93, 0.09) 100%);
}

.logo-mark {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #23cc6e, #0ea258);
  border-radius: 28rpx;
  font-size: 50rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 28rpx rgba(16, 166, 93, 0.24);
}

.brand {
  position: relative;
  z-index: 1;
  color: #202733;
  font-size: 50rpx;
  font-weight: 900;
}

.brand text {
  color: #202733;
}

.brand-sub {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  color: #75827c;
  font-size: 24rpx;
}

.login-sheet {
  margin-top: -20rpx;
  padding: 36rpx 24rpx 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
}

.login-card {
  padding: 30rpx;
}

.wechat-card,
.phone-entry {
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
}

.entry-title {
  color: #17202a;
  font-size: 34rpx;
  font-weight: 900;
}

.wechat-action {
  margin-top: 30rpx;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.phone-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.phone-actions button {
  height: 78rpx;
  line-height: 78rpx;
  margin: 0;
  border-radius: 999rpx;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.close {
  color: #6b7280;
  font-size: 25rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 8rpx;
  background: #eef5f1;
  border-radius: 14rpx;
}

.mode-tab {
  height: 72rpx;
  line-height: 72rpx;
  color: #667281;
  text-align: center;
  border-radius: 10rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.mode-tab.active {
  color: #0f8f52;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(15, 143, 82, 0.12);
}

.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #56616d;
  font-size: 24rpx;
}

input {
  height: 82rpx;
  padding: 0 22rpx;
  color: #17202a;
  background: #fbfcfb;
  border: 1rpx solid #e1e7e1;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.action {
  margin-top: 34rpx;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.secondary-action {
  margin-top: 18rpx;
}

.dev-panel {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 16rpx;
}

.dev-title {
  margin-bottom: 14rpx;
  color: #56616d;
  font-size: 24rpx;
  font-weight: 700;
}

.dev-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.dev-btn {
  margin: 0;
  height: 70rpx;
  line-height: 70rpx;
  color: #16a45a;
  background: #eaf8ef;
  border-radius: 8rpx;
  font-size: 24rpx;
}
