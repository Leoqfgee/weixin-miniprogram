.login-page {
  padding-top: 72rpx;
}

.login-hero {
  margin-bottom: 34rpx;
}

.brand {
  color: #17202a;
  font-size: 54rpx;
  font-weight: 900;
}

.login-card {
  padding: 30rpx;
}

.wechat-card,
.phone-entry {
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
}

.entry-title {
  color: #17202a;
  font-size: 34rpx;
  font-weight: 900;
}

.wechat-action {
  margin-top: 30rpx;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 31rpx;
  font-weight: 900;
}

.phone-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.phone-actions button {
  height: 78rpx;
  line-height: 78rpx;
  margin: 0;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.close {
  color: #6b7280;
  font-size: 25rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 8rpx;
  background: #eef5f1;
  border-radius: 8rpx;
}

.mode-tab {
  height: 72rpx;
  line-height: 72rpx;
  color: #667281;
  text-align: center;
  border-radius: 6rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.mode-tab.active {
  color: #0f8f52;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(15, 143, 82, 0.12);
}

.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #56616d;
  font-size: 24rpx;
}

input {
  height: 82rpx;
  padding: 0 22rpx;
  color: #17202a;
  background: #fbfcfb;
  border: 1rpx solid #e1e7e1;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.action {
  margin-top: 34rpx;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.secondary-action {
  margin-top: 18rpx;
}

.dev-panel {
  margin-top: 24rpx;
  padding: 26rpx;
}

.dev-title {
  margin-bottom: 14rpx;
  color: #56616d;
  font-size: 24rpx;
  font-weight: 700;
}

.dev-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.dev-btn {
  margin: 0;
  height: 70rpx;
  line-height: 70rpx;
  color: #16a45a;
  background: #eaf8ef;
  border-radius: 8rpx;
  font-size: 24rpx;
}
