.login-page {
  padding-top: 70rpx;
}

.login-hero {
  margin-bottom: 34rpx;
}

.brand {
  color: #17202a;
  font-size: 54rpx;
  font-weight: 900;
}

.slogan {
  margin-top: 12rpx;
  color: #697580;
  font-size: 27rpx;
}

.login-card {
  padding: 30rpx;
}

.role-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.role-card {
  flex: 1;
  height: 118rpx;
  padding: 16rpx 10rpx;
  color: #1f7a68;
  background: #f1faf6;
  border: 1rpx solid #c9eadf;
  border-radius: 8rpx;
  line-height: 1.3;
}

.role-name,
.role-phone {
  display: block;
}

.role-name {
  font-size: 26rpx;
  font-weight: 800;
}

.role-phone {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #6b7b75;
}

.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #56616d;
  font-size: 24rpx;
}

input {
  height: 82rpx;
  padding: 0 22rpx;
  color: #17202a;
  background: #f7f4ee;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.action {
  margin-top: 34rpx;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.secondary-action {
  margin-top: 18rpx;
}
