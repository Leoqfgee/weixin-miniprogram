<view class="page login-page">
  <view class="login-hero">
    <view class="brand">校园二手</view>
    <view class="slogan">校内同学之间的闲置交易</view>
  </view>

  <view class="panel login-card">
    <view class="title">登录账号</view>
    <button class="primary-btn action" bindtap="onWechatLogin">微信账号登录</button>
    <button class="ghost-btn action secondary-action" bindtap="togglePasswordLogin">手机号密码登录</button>
    <view wx:if="{{showPasswordLogin}}" class="password-panel">
      <view class="field">
        <text class="field-label">手机号</text>
        <input value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" />
      </view>
      <view class="field">
        <text class="field-label">密码</text>
        <input value="{{password}}" bindinput="onPasswordInput" password placeholder="请输入密码" />
      </view>
      <button class="ghost-btn action secondary-action" bindtap="onLogin">确认登录</button>
    </view>
    <view wx:if="{{devTestEnabled}}" class="dev-panel">
      <view class="dev-title">开发测试账号</view>
      <view class="dev-grid">
        <button wx:for="{{testAccounts}}" wx:key="key" class="dev-btn" data-account="{{item.key}}" bindtap="onDevLogin">{{item.label}}</button>
      </view>
    </view>
  </view>
</view>
