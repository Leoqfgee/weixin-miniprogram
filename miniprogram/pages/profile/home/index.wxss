.profile {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 8rpx;
  flex: none;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1f7a68;
  color: #fff;
  font-size: 44rpx;
  font-weight: 800;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.section-title {
  margin: 26rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.bio{margin-top:8rpx}.stats{display:flex;flex-wrap:wrap;gap:12rpx;margin-top:12rpx;font-size:23rpx}.reviews{display:flex;flex-direction:column;gap:14rpx}.review-head{display:flex;justify-content:space-between;margin-bottom:10rpx}.rating{color:#f2ad3d;font-weight:800}.empty-review{padding:20rpx 0}
