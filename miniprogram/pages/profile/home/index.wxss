.profile-home-page {
  padding-bottom: 80rpx;
}

.profile-hero {
  margin-top: 0;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  box-shadow: 0 16rpx 34rpx rgba(20, 79, 50, 0.12);
}

.avatar {
  float: left;
  width: 118rpx;
  height: 118rpx;
  margin-right: 22rpx;
  border: 6rpx solid #ffffff;
  border-radius: 50%;
  background: #e7eee9;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #18b86c;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
}

.profile-main {
  min-width: 0;
  min-height: 132rpx;
}

.section-title {
  margin: 26rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
.bio {
  margin-top: 10rpx;
  color: #66717c;
  font-size: 24rpx;
}

.stats {
  clear: both;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #eaf0ec;
}

.stats view {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats text:first-child {
  color: #202733;
  font-size: 34rpx;
  font-weight: 900;
}

.stats text:last-child {
  margin-top: 6rpx;
  color: #7a858f;
  font-size: 22rpx;
}

.reviews {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.review {
  border-radius: 14rpx;
}

.review-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.rating {
  color: #0fa960;
  font-weight: 800;
}

.empty-review {
  padding: 20rpx 0;
}
