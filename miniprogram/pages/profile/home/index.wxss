.profile-home-page{padding-bottom:80rpx}.profile-hero{padding:30rpx;background:rgba(255,255,255,.96);border-radius:16rpx;box-shadow:0 16rpx 34rpx rgba(20,79,50,.12)}.profile-top{display:flex;gap:22rpx;align-items:center}.avatar{width:118rpx;height:118rpx;border:6rpx solid #fff;border-radius:50%;background:#e7eee9;flex:none}.placeholder{display:flex;align-items:center;justify-content:center;background:#18b86c;color:#fff;font-size:44rpx;font-weight:900}.profile-main{min-width:0;flex:1}.title{color:#1f2933;font-size:38rpx;font-weight:900}.bio{display:-webkit-box;margin-top:10rpx;color:#66717c;font-size:24rpx;line-height:1.45;overflow:hidden;text-overflow:ellipsis;-webkit-line-clamp:2;-webkit-box-orient:vertical}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12rpx;margin-top:22rpx;padding-top:22rpx;border-top:1rpx solid #eaf0ec}.stats view{display:flex;flex-direction:column;align-items:center}.stats text:first-child{color:#202733;font-size:34rpx;font-weight:900}.stats text:last-child{margin-top:6rpx;color:#7a858f;font-size:22rpx}.section-title{margin:26rpx 0 16rpx;color:#17202a;font-size:30rpx;font-weight:900}.reviews{display:flex;flex-direction:column;gap:14rpx}.review{border-radius:14rpx}.review-head{display:flex;justify-content:space-between;margin-bottom:10rpx}.rating{color:#0fa960;font-weight:800}.empty-review{padding:24rpx;color:#7a8491;text-align:center}.product-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16rpx}
