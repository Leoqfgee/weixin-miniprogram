<view class="page profile-home-page green-page">
  <view wx:if="{{profile}}" class="profile-hero"><view class="profile-top"><image wx:if="{{profile.avatar || profile.avatar_url}}" class="avatar" src="{{profile.avatar || profile.avatar_url}}" mode="aspectFill"></image><view wx:else class="avatar placeholder">{{avatarText}}</view><view class="profile-main"><view class="title">{{profile.nickname}}</view><view class="muted">{{profile.campus}}</view><view class="bio">{{profile.bio}}</view></view></view><view class="stats"><view><text>{{profile.publish_count}}</text><text>累计发布</text></view><view><text>{{profile.deal_count}}</text><text>成交订单</text></view><view><text>{{profile.good_rate}}%</text><text>好评率</text></view><view><text>{{profile.credit_score}}</text><text>信用分</text></view></view></view>
  <view class="section-title">收到的评价（{{profile.review_count || 0}}）</view>
  <view wx:if="{{reviews.length}}" class="reviews"><view wx:for="{{reviews}}" wx:key="id" class="panel review" data-id="{{item.id}}" bindtap="viewReview"><view class="review-head"><text class="text-strong">{{item.reviewer.nickname || '校内同学'}}</text><text class="rating">{{item.rating}} 星</text></view><view class="muted">{{item.content || '未填写评价内容'}}</view></view></view>
  <view wx:else class="panel empty-review">暂无评价</view>
  <view class="section-title">在售商品</view><view wx:if="{{products.length}}" class="product-grid"><product-card wx:for="{{products}}" wx:key="id" product="{{item}}" layout="grid"></product-card></view><empty-state wx:else title="暂无在售商品"></empty-state>
</view>
