<view class="page">
  <view wx:if="{{profile}}" class="panel profile"><image wx:if="{{profile.avatar || profile.avatar_url}}" class="avatar" src="{{profile.avatar || profile.avatar_url}}" mode="aspectFill"></image><view wx:else class="avatar placeholder">{{avatarText}}</view><view class="profile-main"><view class="title">{{profile.nickname}}</view><view class="muted">{{profile.campus || '未填写校区'}} · 信用分 {{profile.credit_score || 100}}</view><view class="muted bio">{{profile.bio || '这个同学还没有填写简介'}}</view><view class="stats"><text>累计发布 {{profile.publish_count || 0}}</text><text>成交订单 {{profile.deal_count || 0}}</text><text>好评率 {{profile.good_rate}}%</text></view></view></view>
  <view class="section-title">收到的评价（{{profile.review_count || 0}}）</view>
  <view wx:if="{{reviews.length}}" class="reviews"><view wx:for="{{reviews}}" wx:key="id" class="panel review" data-id="{{item.id}}" bindtap="viewReview"><view class="review-head"><text class="text-strong">{{item.reviewer.nickname}}</text><text class="rating">{{item.rating}} ★</text></view><view class="muted">{{item.content || '未填写评价内容'}}</view></view></view>
  <view wx:else class="muted empty-review">暂无评价</view>
  <view class="section-title">在售商品</view><view wx:if="{{products.length}}" class="list"><product-card wx:for="{{products}}" wx:key="id" product="{{item}}"></product-card></view><empty-state wx:else title="暂无在售商品" description="稍后再来看看"></empty-state>
</view>
