<view class="page">
  <view class="panel form">
    <view wx:if="{{completeMode}}" class="notice">登录成功，请先完善平台资料</view>

    <view class="avatar-row">
      <image wx:if="{{form.avatar}}" class="avatar" src="{{form.avatar}}" mode="aspectFill"></image>
      <view wx:else class="avatar placeholder">头像</view>
      <view class="avatar-actions">
        <button wx:if="{{canUseWechatAvatar}}" class="ghost-btn compact" open-type="chooseAvatar" bindchooseavatar="onChooseWechatAvatar">设置头像</button>
        <button wx:else class="ghost-btn compact" bindtap="openAvatarSheet">设置头像</button>
        <view wx:if="{{avatarUploading}}" class="uploading">头像上传中</view>
      </view>
    </view>
    <view class="field">
      <text>昵称</text>
      <input value="{{form.nickname}}" type="nickname" data-field="nickname" bindinput="onInput" placeholder="请输入昵称" />
    </view>
    <view class="field">
      <text>校区</text>
      <input value="{{form.campus}}" data-field="campus" bindinput="onInput" placeholder="例如 主校区" />
    </view>
    <view class="field">
      <text>联系电话</text>
      <input value="{{form.contact_phone}}" type="number" maxlength="11" data-field="contact_phone" bindinput="onInput" placeholder="可选手机号" />
    </view>
    <view class="field">
      <text>微信号</text>
      <input value="{{form.contact_wechat}}" data-field="contact_wechat" bindinput="onInput" placeholder="可选，交易联系使用" />
    </view>
    <view class="field">
      <text>简介</text>
      <textarea value="{{form.bio}}" data-field="bio" bindinput="onInput" maxlength="120" placeholder="一句话介绍自己"></textarea>
    </view>
    <button class="primary-btn" bindtap="saveProfile">保存</button>
  </view>
</view>
