.form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.notice {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #eaf8ef;
  color: #16a45a;
  font-size: 26rpx;
}

.avatar-actions {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.compact {
  align-self: flex-start;
  min-width: 220rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.uploading {
  color: #16a45a;
  font-size: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #16b85e;
  color: #fff;
  font-size: 24rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #56616d;
  font-size: 24rpx;
}

input,
textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #fbfcfb;
  border: 1rpx solid #e1e7e1;
}

textarea {
  min-height: 160rpx;
}
