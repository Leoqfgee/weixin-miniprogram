.form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.notice {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #eaf8ef;
  color: #16a45a;
  font-size: 26rpx;
}

.avatar-actions {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.compact {
  align-self: flex-start;
  min-width: 220rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.compact.light {
  color: #56616d;
  background: #f5f7fa;
}

.uploading {
  color: #16a45a;
  font-size: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #16b85e;
  color: #fff;
  font-size: 24rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #56616d;
  font-size: 24rpx;
}

input,
textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #fbfcfb;
  border: 1rpx solid #e1e7e1;
}

textarea {
  min-height: 160rpx;
}

.avatar-sheet-mask {
  position: fixed;
  z-index: 90;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.55);
}

.avatar-sheet {
  width: 100%;
  overflow: hidden;
  background: #ffffff;
  border-radius: 16rpx 16rpx 0 0;
}

.sheet-item {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  margin: 0;
  color: #111827;
  background: #ffffff;
  border-radius: 0;
  font-size: 30rpx;
}

.sheet-item::after {
  border: 0;
  border-bottom: 1rpx solid #eef0f2;
}

.sheet-item.cancel {
  margin-top: 12rpx;
}
