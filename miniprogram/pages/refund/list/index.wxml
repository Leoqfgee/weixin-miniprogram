<view class="refund-page"><view class="role-tabs"><view wx:for="{{roleTabs}}" wx:key="value" class="role-tab {{index === activeRoleIndex ? 'active' : ''}}" data-index="{{index}}" bindtap="selectRole">{{item.label}}</view></view><scroll-view scroll-x class="tabs"><view class="tabs-inner"><view wx:for="{{tabs}}" wx:key="value" class="tab {{index === activeTab ? 'active' : ''}}" data-index="{{index}}" bindtap="selectTab">{{item.label}}<text wx:if="{{item.value === 'pending' && pendingCount > 0}}" class="tab-badge">{{pendingCount}}</text></view></view></scroll-view><view wx:if="{{loadError && !refunds.length}}" class="error-panel">售后列表加载失败，请下拉重试</view><view wx:if="{{refunds.length}}" class="refund-list"><view wx:for="{{refunds}}" wx:key="id" class="refund-card" data-id="{{item.id}}" bindtap="goDetail"><view class="card-head"><view class="refund-no">售后单号：{{item.after_sale_no || item.refund_no}}</view><text class="status status-{{item.status_group}}">{{item.status_text}}</text></view><view class="product-row"><image wx:if="{{item.product.cover_image}}" class="product-img" src="{{item.product.cover_image}}" mode="aspectFill"></image><view wx:else class="product-img placeholder">图</view><view class="product-info"><view class="product-title">{{item.product.title}}</view><view class="amount-line">退款金额：<text>{{item.amount_text}}</text></view><view class="product-spec">申请时间：{{item.created_text}}</view></view></view><view class="reason-row"><text>退款原因：{{item.reason_display}}</text><text>{{item.counterparty_label}}：{{item.counterparty.nickname}}</text></view><view class="card-actions"><button wx:if="{{item.permissions.can_seller_handle}}" class="primary-btn" data-id="{{item.id}}" catchtap="goDetail">去处理</button><button wx:else class="ghost-btn" data-id="{{item.id}}" catchtap="goDetail">查看详情</button></view></view></view><empty-state wx:elif="{{!loading && !loadError}}" title="暂无售后申请"></empty-state><view wx:if="{{finished && refunds.length}}" class="bottom-text">没有更多了</view></view>
