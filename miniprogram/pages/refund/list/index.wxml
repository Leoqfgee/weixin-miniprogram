<view class="page">
  <view wx:if="{{refunds.length}}" class="list">
    <view wx:for="{{refunds}}" wx:key="id" class="panel item">
      <view class="title small">售后 {{item.refund_no || item.id}}</view>
      <view class="muted">订单：{{item.order_no || item.order_id}}</view>
      <view class="product-line">
        <image wx:if="{{item.product.cover_image}}" class="thumb" src="{{item.product.cover_image}}" mode="aspectFill"></image>
        <view wx:else class="thumb placeholder">售</view>
        <view>
          <view class="text-strong">{{item.product.title || '售后商品'}}</view>
          <view class="muted">申请金额：￥{{item.request_amount || item.amount}} · 状态：{{item.status}}</view>
          <view wx:if="{{item.final_refund_amount}}" class="muted">最终退款：￥{{item.final_refund_amount}}</view>
        </view>
      </view>
      <view class="reason">原因：{{item.reason}}</view>
      <view wx:if="{{item.description}}" class="muted">说明：{{item.description}}</view>
      <view class="muted">申请人：{{item.applicant.nickname}} · 买家：{{item.buyer.nickname}} · 卖家：{{item.seller.nickname}}</view>
      <view wx:if="{{item.seller_response}}" class="muted">卖家处理：{{item.seller_response}}</view>
      <view wx:if="{{item.admin_reason}}" class="muted">平台处理：{{item.admin_decision}} {{item.admin_reason}}</view>
      <view class="timeline">
        <view wx:for="{{item.timeline}}" wx:key="label" wx:for-item="step" class="muted">{{step.label}} {{step.time || ''}}</view>
      </view>
      <view class="actions">
        <button wx:if="{{item.permissions.can_seller_handle}}" class="ghost-btn" data-id="{{item.id}}" data-result="rejected" bindtap="sellerHandle">拒绝售后</button>
        <button wx:if="{{item.permissions.can_seller_handle}}" class="ghost-btn" data-id="{{item.id}}" data-result="partial_refund" bindtap="sellerHandle">部分退款</button>
        <button wx:if="{{item.permissions.can_seller_handle}}" class="primary-btn" data-id="{{item.id}}" data-result="approved" bindtap="sellerHandle">同意全额退款</button>
        <button wx:if="{{isAdmin && item.permissions.can_admin_arbitrate}}" class="ghost-btn" data-id="{{item.id}}" data-result="rejected" bindtap="arbitrate">支持卖家拒绝</button>
        <button wx:if="{{isAdmin && item.permissions.can_admin_arbitrate}}" class="ghost-btn" data-id="{{item.id}}" data-result="partial_refund" bindtap="arbitrate">部分退款</button>
        <button wx:if="{{isAdmin && item.permissions.can_admin_arbitrate}}" class="primary-btn" data-id="{{item.id}}" data-result="approved" bindtap="arbitrate">支持买家退款</button>
      </view>
    </view>
  </view>
  <empty-state wx:else title="暂无售后记录" description="订单详情页可申请售后"></empty-state>
</view>
