.refund-page { min-height: 100vh; background: #f5f8f6; color: #202733; padding-bottom: 40rpx; }
.top-bar { position: sticky; top: 0; z-index: 120; height: 150rpx; padding-top: 58rpx; box-sizing: border-box; color: #fff; background: linear-gradient(135deg,#18a873,#28bf83); }
.back-btn { position: absolute; left: 22rpx; top: 54rpx; width: 66rpx; height: 66rpx; line-height: 60rpx; text-align: center; font-size: 56rpx; font-weight: 300; }
.nav-title { text-align: center; font-size: 34rpx; font-weight: 900; }
.role-tabs { position: sticky; top: 150rpx; z-index: 110; display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; padding: 18rpx 24rpx; background: #fff; }
.role-tab { height: 72rpx; line-height: 72rpx; color: #667281; text-align: center; background: #eef5f1; border-radius: 999rpx; font-size: 28rpx; font-weight: 800; }
.role-tab.active { color: #fff; background: #13b86b; }
.tabs { position: sticky; top: 240rpx; z-index: 105; background: #fff; white-space: nowrap; border-bottom: 1rpx solid #edf2ee; }
.tabs-inner { display: inline-flex; gap: 8rpx; padding: 0 18rpx; }
.tab { position: relative; min-width: 124rpx; height: 82rpx; line-height: 82rpx; color: #6b7280; text-align: center; font-size: 26rpx; font-weight: 700; }
.tab.active { color: #0f9f5b; }
.tab.active::after { content: ''; position: absolute; left: 30rpx; right: 30rpx; bottom: 10rpx; height: 6rpx; border-radius: 6rpx; background: #13b86b; }
.tab-badge { position: absolute; top: 10rpx; right: 14rpx; min-width: 30rpx; height: 30rpx; line-height: 30rpx; color: #fff; background: #ef4444; border-radius: 999rpx; font-size: 20rpx; }
.hint-row { display: flex; align-items: center; gap: 10rpx; padding: 18rpx 24rpx 0; color: #66717d; font-size: 24rpx; }
.hint-icon { width: 28rpx; height: 28rpx; line-height: 28rpx; color: #fff; background: #16a45a; border-radius: 50%; text-align: center; font-size: 18rpx; }
.refund-list { padding: 18rpx 22rpx 30rpx; }
.refund-card { margin-bottom: 18rpx; padding: 22rpx; background: #fff; border: 1rpx solid #e8f0ea; border-radius: 22rpx; box-shadow: 0 10rpx 26rpx rgba(31,41,51,.06); }
.card-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.refund-no { flex: 1; min-width: 0; color: #5f6b77; font-size: 23rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.copy { margin-left: 10rpx; color: #0f9f5b; font-size: 22rpx; }
.status { flex: none; padding: 7rpx 14rpx; border-radius: 999rpx; font-size: 23rpx; font-weight: 800; }
.status-pending { color: #f97316; background: #fff3e8; } .status-refunding { color: #2563eb; background: #eaf1ff; } .status-refunded { color: #0f9f5b; background: #eaf8f0; } .status-rejected, .status-closed { color: #66717d; background: #f1f4f6; }
.product-row { display: flex; gap: 18rpx; margin-top: 18rpx; }
.product-img { width: 144rpx; height: 144rpx; flex: none; border-radius: 16rpx; background: #edf3ef; }
.placeholder { display: flex; align-items: center; justify-content: center; color: #fff; background: #16b86b; font-weight: 900; }
.product-info { flex: 1; min-width: 0; }
.product-title { display: -webkit-box; color: #17212b; font-size: 28rpx; line-height: 1.35; font-weight: 900; overflow: hidden; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.product-spec { margin-top: 8rpx; color: #7b8794; font-size: 23rpx; }
.amount-line { margin-top: 12rpx; color: #66717d; font-size: 24rpx; } .amount-line text { color: #ef4444; font-size: 30rpx; font-weight: 900; }
.buyer-row { display: flex; align-items: center; flex-wrap: wrap; gap: 10rpx; margin-top: 18rpx; padding-top: 16rpx; border-top: 1rpx solid #edf2ee; color: #66717d; font-size: 23rpx; }
.avatar { width: 38rpx; height: 38rpx; border-radius: 50%; background: #edf3ef; }
.buyer-name { color: #344054; font-weight: 700; }
.phone { display: none; }
.apply-time { margin-left: auto; }
.reason-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8rpx 18rpx; margin-top: 14rpx; color: #566170; font-size: 23rpx; }
.card-actions { display: flex; justify-content: flex-end; gap: 14rpx; margin-top: 18rpx; }
.card-actions button { min-width: 168rpx; height: 64rpx; line-height: 62rpx; margin: 0; border-radius: 999rpx; font-size: 24rpx; }
.error-panel { margin: 22rpx; padding: 24rpx; color: #ef4444; background: #fff; border-radius: 18rpx; }
.bottom-text { padding: 18rpx 0 28rpx; text-align: center; color: #9aa5ad; font-size: 24rpx; }
