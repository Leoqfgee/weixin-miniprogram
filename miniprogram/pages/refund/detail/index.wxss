.detail-page { min-height: 100vh; padding-bottom: 150rpx; background: #f5f8f6; color: #202733; }
.top-bar { position: sticky; top: 0; z-index: 120; height: 150rpx; padding-top: 58rpx; box-sizing: border-box; color: #fff; background: linear-gradient(135deg,#18a873,#28bf83); }
.back-btn { position: absolute; left: 22rpx; top: 54rpx; width: 66rpx; height: 66rpx; line-height: 60rpx; text-align: center; font-size: 56rpx; font-weight: 300; }
.nav-title { text-align: center; font-size: 34rpx; font-weight: 900; }
.status-tip { display: flex; flex-direction: column; gap: 8rpx; margin: 20rpx 22rpx; padding: 24rpx; color: #2f3b46; background: linear-gradient(135deg,#effaf4,#ffffff); border: 1rpx solid #dcefe5; border-radius: 22rpx; font-size: 25rpx; }
.status-text { color: #0f9f5b; font-size: 34rpx; font-weight: 900; }
.status-pending .status-text { color: #f97316; } .status-refunding .status-text { color: #2563eb; } .status-rejected .status-text, .status-closed .status-text { color: #66717d; }
.section { margin: 18rpx 22rpx; padding: 24rpx; background: #fff; border: 1rpx solid #e8f0ea; border-radius: 22rpx; box-shadow: 0 10rpx 26rpx rgba(31,41,51,.06); }
.section-title { margin-bottom: 20rpx; color: #17212b; font-size: 31rpx; font-weight: 900; }
.section-title::before { content: ''; display: inline-block; width: 8rpx; height: 28rpx; margin-right: 12rpx; vertical-align: -5rpx; background: #18b86c; border-radius: 999rpx; }
.kv { display: flex; justify-content: space-between; gap: 22rpx; padding: 12rpx 0; color: #334155; font-size: 26rpx; line-height: 1.5; }
.kv > text:first-child { flex: none; color: #7b8794; }
.kv > text:last-child, .kv > view { text-align: right; word-break: break-all; }
.kv.block { align-items: flex-start; }
.copy { margin-left: 12rpx; color: #0f9f5b; font-size: 22rpx; }
.state { color: #0f9f5b; font-weight: 800; }
.product-row { display: flex; gap: 18rpx; }
.product-img { width: 150rpx; height: 150rpx; flex: none; border-radius: 16rpx; background: #edf3ef; }
.placeholder { display: flex; align-items: center; justify-content: center; color: #fff; background: #16b86b; font-weight: 900; }
.product-info { flex: 1; min-width: 0; }
.product-title { color: #17212b; font-size: 29rpx; line-height: 1.35; font-weight: 900; }
.product-spec { margin-top: 10rpx; color: #7b8794; font-size: 24rpx; }
.product-price { margin-top: 14rpx; color: #ef4444; font-size: 31rpx; font-weight: 900; }
.product-price text { float: right; color: #475467; font-size: 24rpx; }
.buyer-info { display: flex; align-items: center; gap: 18rpx; }
.buyer-avatar { width: 82rpx; height: 82rpx; flex: none; border-radius: 50%; background: #edf3ef; }
.buyer-main { flex: 1; min-width: 0; color: #17212b; font-size: 28rpx; font-weight: 900; }
.buyer-phone { margin-top: 8rpx; color: #66717d; font-size: 23rpx; font-weight: 500; }
.contact-btn { width: 174rpx; height: 66rpx; line-height: 64rpx; margin: 0; color: #0f9f5b; background: #fff; border: 1rpx solid #13b86b; border-radius: 999rpx; font-size: 24rpx; }
.amount { color: #ef4444; font-size: 31rpx; font-weight: 900; }
.evidence { margin-top: 14rpx; }.label { color: #7b8794; font-size: 25rpx; }.evidence-list { display: flex; flex-wrap: wrap; gap: 14rpx; margin-top: 12rpx; }.evidence-img { width: 150rpx; height: 150rpx; border-radius: 14rpx; background: #edf3ef; }
.action-bar { position: fixed; left: 0; right: 0; bottom: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom)); background: #fff; box-shadow: 0 -10rpx 30rpx rgba(31,41,51,.08); }
.action-bar button { height: 82rpx; line-height: 80rpx; margin: 0; border-radius: 999rpx; font-size: 28rpx; font-weight: 900; }
.action-hint { grid-column: 1 / -1; color: #8b96a3; text-align: center; font-size: 22rpx; }
