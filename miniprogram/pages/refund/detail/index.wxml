<view class="detail-page" wx:if="{{refund}}"><view class="status-tip status-{{refund.status_group}}"><text class="status-text">{{refund.status_text}}</text><text>{{refund.status_tip}}</text></view><view class="section"><view class="section-title">售后信息</view><view class="kv"><text>售后类型</text><text>{{refund.refund_type_text || '仅退款'}}</text></view><view class="kv"><text>申请时间</text><text>{{refund.created_text}}</text></view><view class="kv"><text>当前状态</text><text class="state">{{refund.status_text}}</text></view></view><view class="section"><view class="section-title">商品信息</view><view class="product-row"><image wx:if="{{refund.product.cover_image}}" class="product-img" src="{{refund.product.cover_image}}" mode="aspectFill"></image><view wx:else class="product-img placeholder">图</view><view class="product-info"><view class="product-title">{{refund.product.title}}</view><view class="product-spec">数量：{{refund.product.quantity}}</view><view class="product-price">{{refund.product.price_text}}</view></view></view></view><view class="section"><view class="section-title">{{refund.contact_title}}</view><view class="buyer-info"><image class="buyer-avatar" src="{{refund.contact_user.avatar || '/assets/tabbar/mine.png'}}" mode="aspectFill"></image><view class="buyer-main"><view>{{refund.contact_user.nickname}}</view><view class="buyer-phone">手机号：{{refund.contact_user.phone_masked}}</view></view><button class="contact-btn" bindtap="contactCounterparty">{{refund.contact_label}}</button></view></view><view class="section"><view class="section-title">退款信息</view><view class="kv"><text>退款金额</text><text class="amount">{{refund.amount_text}}</text></view><view class="kv"><text>退款原因</text><text>{{refund.reason_display}}</text></view><view class="kv block"><text>问题描述</text><text>{{refund.description_display}}</text></view><view wx:if="{{refund.evidence_images && refund.evidence_images.length}}" class="evidence"><view class="label">凭证图片</view><view class="evidence-list"><image wx:for="{{refund.evidence_images}}" wx:key="*this" class="evidence-img" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewEvidence"></image></view></view></view><view wx:if="{{refund.delivery && (refund.delivery.express_company || refund.delivery.tracking_no)}}" class="section"><view class="section-title">物流信息</view><view wx:if="{{refund.delivery.express_company}}" class="kv"><text>快递公司</text><text>{{refund.delivery.express_company}}</text></view><view wx:if="{{refund.delivery.tracking_no}}" class="kv"><text>快递单号</text><text>{{refund.delivery.tracking_no}}</text></view></view><view class="section result-section" wx:if="{{!refund.permissions.can_seller_handle && refund.seller_response}}"><view class="section-title">处理结果</view><view class="kv block"><text>处理说明</text><text>{{refund.seller_response}}</text></view><view wx:if="{{refund.seller_handled_at}}" class="kv"><text>处理时间</text><text>{{refund.handled_text}}</text></view></view><view wx:if="{{refund.permissions.can_seller_handle}}" class="action-bar"><button class="ghost-btn refuse" bindtap="refuseRefund">拒绝退款</button><button class="primary-btn agree" bindtap="agreeRefund">同意退款</button></view></view><view wx:else class="detail-page"><empty-state title="售后详情加载中"></empty-state></view>
