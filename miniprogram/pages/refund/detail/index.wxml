<view class="detail-page" wx:if="{{refund}}">
  <view class="top-bar"><view class="back-btn" bindtap="goBack">‹</view><view class="nav-title">售后详情</view></view>
<view class="status-tip status-{{refund.status_group}}">
    <text class="status-text">{{refund.status_text}}</text>
    <text>{{refund.status_tip}}</text>
  </view>

  <view class="section">
    <view class="section-title">1. 售后信息</view>
    <view class="kv">
      <text>售后单号</text>
      <view><text>{{refund.after_sale_no || refund.refund_no}}</text><text class="copy" data-value="{{refund.after_sale_no || refund.refund_no}}" bindtap="copyText">复制</text></view>
    </view>
    <view class="kv">
      <text>订单编号</text>
      <view><text>{{refund.order_no}}</text><text class="copy" data-value="{{refund.order_no}}" bindtap="copyText">复制</text></view>
    </view>
    <view class="kv"><text>申请时间</text><text>{{refund.display_time}}</text></view>
    <view class="kv"><text>当前状态</text><text class="state">{{refund.status_text}}</text></view>
  </view>

  <view class="section">
    <view class="section-title">2. 商品信息</view>
    <view class="product-row">
      <image wx:if="{{refund.product.cover_image}}" class="product-img" src="{{refund.product.cover_image}}" mode="aspectFill"></image>
      <view wx:else class="product-img placeholder">图</view>
      <view class="product-info">
        <view class="product-title">{{refund.product.title || '售后商品'}}</view>
        <view class="product-spec">{{refund.product.display_condition || '规格/成色暂无'}}</view>
        <view class="product-price">{{refund.product.display_price || refund.display_amount}} <text>x{{refund.product.quantity || 1}}</text></view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">3. {{refund.current_role === 'buyer' ? '卖家信息' : '买家信息'}}</view>
    <view class="buyer-info">
      <image class="buyer-avatar" src="{{refund.contact_user.avatar || '/assets/tabbar/mine.png'}}" mode="aspectFill"></image>
      <view class="buyer-main">
        <view>{{refund.contact_user.nickname || '校园同学'}}</view>
        <view class="buyer-phone">☎ {{refund.contact_user.phone_masked || '未留手机号'}}</view>
      </view>
      <button class="contact-btn" bindtap="contactCounterparty">{{refund.contact_label}}</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">4. 退款信息</view>
    <view class="kv"><text>退款金额</text><text class="amount">{{refund.display_amount}}</text></view>
    <view class="kv"><text>售后类型</text><text>{{refund.display_refund_type || '仅退款'}}</text></view>
    <view class="kv"><text>退款原因</text><text>{{refund.display_reason}}</text></view>
    <view class="kv block"><text>问题描述</text><text>{{refund.description || '未填写'}}</text></view>
    <view wx:if="{{refund.evidence_images && refund.evidence_images.length}}" class="evidence">
      <view class="label">凭证图片</view>
      <view class="evidence-list">
        <image wx:for="{{refund.evidence_images}}" wx:key="*this" class="evidence-img" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewEvidence"></image>
      </view>
    </view>
  </view>

  <view wx:if="{{refund.delivery && (refund.delivery.express_company || refund.delivery.tracking_no)}}" class="section">
    <view class="section-title">5. 物流信息</view>
    <view wx:if="{{refund.delivery.express_company}}" class="kv"><text>快递公司</text><text>{{refund.delivery.express_company}}</text></view>
    <view wx:if="{{refund.delivery.tracking_no}}" class="kv">
      <text>快递单号</text>
      <view><text>{{refund.delivery.tracking_no}}</text><text class="copy" data-value="{{refund.delivery.tracking_no}}" bindtap="copyText">复制</text></view>
    </view>
  </view>

  <view class="section result-section" wx:if="{{!refund.permissions.can_seller_handle && refund.seller_response}}">
    <view class="section-title">处理结果</view>
    <view class="kv block"><text>卖家处理说明</text><text>{{refund.seller_response}}</text></view>
    <view wx:if="{{refund.seller_handled_at}}" class="kv"><text>处理时间</text><text>{{refund.seller_handled_at}}</text></view>
  </view>

  <view wx:if="{{refund.permissions.can_seller_handle}}" class="action-bar">
    <button class="ghost-btn refuse" bindtap="refuseRefund">拒绝退款</button>
    <button class="primary-btn agree" bindtap="agreeRefund">同意退款</button>
    <view class="action-hint">如有疑问，可联系对方协商处理</view>
  </view>
</view>

<view wx:else class="detail-page">
  <view class="top-bar"><view class="back-btn" bindtap="goBack">‹</view><view class="nav-title">售后详情</view></view>
  <empty-state title="售后详情加载中"></empty-state>
</view>
