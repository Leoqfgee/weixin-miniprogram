.chat-page {
  padding: 18rpx 24rpx 118rpx;
}

.product-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(31, 41, 51, 0.07);
}

.product-cover {
  width: 156rpx;
  height: 116rpx;
  border-radius: 18rpx;
  background: #edf3ee;
  flex: none;
}

.product-main {
  flex: 1;
  min-width: 0;
}

.product-main .text-strong {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  font-size: 29rpx;
}

.price {
  margin-top: 8rpx;
  color: #f04438;
  font-size: 34rpx;
  font-weight: 900;
}

.context-tip {
  margin-top: 6rpx;
  color: #7a8491;
  font-size: 22rpx;
}

.chevron {
  color: #9aa2ad;
  font-size: 46rpx;
}

.messages {
  box-sizing: border-box;
  height: calc(100vh - 410rpx);
  padding: 26rpx 0;
}

.time-separator {
  margin: 24rpx 0;
  color: #9aa2ad;
  text-align: center;
  font-size: 24rpx;
}

.system-message {
  max-width: 86%;
  margin: 18rpx auto;
  padding: 12rpx 18rpx;
  color: #6b7480;
  background: #eef1ee;
  border-radius: 999rpx;
  text-align: center;
  font-size: 23rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin: 22rpx 0;
}

.message-row.mine {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #dfe5ea;
  flex: none;
}

.message-main {
  max-width: 72%;
}

.mine .message-main {
  text-align: right;
}

.bubble {
  display: inline-block;
  max-width: 100%;
  padding: 18rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid #edf1ed;
  border-radius: 18rpx;
  text-align: left;
  line-height: 1.55;
  word-break: break-word;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.06);
}

.mine .bubble {
  color: #ffffff;
  background: linear-gradient(135deg, #21c767, #12a85b);
  border-color: #16b85e;
}

.read-state {
  margin-top: 8rpx;
  color: #9aa2ad;
  font-size: 21rpx;
}

.chat-image,
.chat-video {
  width: 300rpx;
  border-radius: 14rpx;
}

.voice {
  min-width: 180rpx;
}

.composer {
  box-sizing: border-box;
  position: fixed;
  z-index: 5;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  width: 100%;
  padding: 16rpx 20rpx 26rpx;
  background: rgba(255, 255, 255, 0.97);
}

.message-input,
.voice-btn {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 28rpx;
  background: #f7f8f5;
  border: 1rpx solid #e8ece8;
  border-radius: 999rpx;
}

.voice-btn {
  margin: 0;
  color: #1f2933;
  font-size: 25rpx;
}

.icon-btn,
.send-btn {
  flex: 0 0 70rpx;
  width: 70rpx;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  padding: 0;
  background: #ffffff;
  border: 0;
  font-size: 32rpx;
}

.send-btn {
  flex-basis: 104rpx;
  width: 104rpx;
  color: #ffffff;
  background: #16b85e;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.tray {
  position: fixed;
  z-index: 4;
  left: 0;
  right: 0;
  bottom: 112rpx;
  display: grid;
  padding: 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #e8ece8;
}

.emoji-tray {
  grid-template-columns: repeat(8, 1fr);
  gap: 10rpx;
}

.emoji-tray view {
  text-align: center;
  padding: 14rpx 6rpx;
  background: #f7f8f5;
  border-radius: 14rpx;
  font-size: 32rpx;
}
