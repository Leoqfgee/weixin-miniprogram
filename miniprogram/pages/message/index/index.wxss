page {
  background: #f7f8f5;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #edf3ee;
  flex: none;
}

.main {
  flex: 1;
  min-width: 0;
}

.last {
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 7rpx;
  text-align: center;
  color: #ffffff;
  background: #f04438;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}
