.message-page { padding: 22rpx 22rpx 120rpx; background: #f5f8f6; }
.conversation-list { display: flex; flex-direction: column; gap: 18rpx; }
.conversation-card { position: relative; display: flex; align-items: center; gap: 18rpx; min-height: 136rpx; padding: 18rpx; background: #fff; border: 1rpx solid #e8f0ea; border-radius: 20rpx; box-shadow: 0 10rpx 24rpx rgba(31,41,51,.06); }
.conversation-card.service { background: linear-gradient(135deg,#ffffff,#f5fff9); }
.avatar { flex: none; width: 82rpx; height: 82rpx; border-radius: 50%; background: #edf3ef; }
.main { flex: 1; min-width: 0; }
.row-top { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.nickname { color: #1d2730; font-size: 28rpx; font-weight: 900; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.time { flex: none; color: #99a3ad; font-size: 22rpx; }
.product-line { display: flex; align-items: center; gap: 10rpx; margin-top: 8rpx; color: #66717d; font-size: 23rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.product-line text:first-child { flex: none; padding: 4rpx 10rpx; color: #0c9a56; background: #eaf8f0; border-radius: 999rpx; font-size: 20rpx; }
.product-line text:last-child { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.last { margin-top: 8rpx; color: #4b5563; font-size: 24rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.badge { position: absolute; right: 18rpx; top: 18rpx; min-width: 30rpx; height: 30rpx; line-height: 30rpx; padding: 0 7rpx; text-align: center; color: #fff; background: #ef4444; border-radius: 999rpx; font-size: 20rpx; }

.product-thumb { flex: none; width: 92rpx; height: 92rpx; border-radius: 16rpx; background: #eef3ef; }
.conversation-card .badge { right: 104rpx; top: 14rpx; }
.conversation-card.service .badge { right: 18rpx; }
