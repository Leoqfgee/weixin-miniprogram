.message-page{padding-bottom:118rpx;background:#f6f8f6}.conversation-list{display:flex;flex-direction:column;gap:18rpx}.conversation-card{display:flex;gap:18rpx;padding:22rpx;background:#fff;border:1rpx solid #edf1ed;border-radius:16rpx;box-shadow:0 8rpx 24rpx rgba(31,41,51,.05)}.service-card{background:#fbfffd;border-color:#dcefe5}.avatar{width:88rpx;height:88rpx;border-radius:50%;background:#edf3ee;flex:none}.main{flex:1;min-width:0}.top-line{display:flex;align-items:center;justify-content:space-between;gap:12rpx}.name{color:#1f2933;font-size:30rpx;font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.time{flex:none;color:#98a2ad;font-size:22rpx}.product-line{display:block;max-width:430rpx;margin-top:8rpx;color:#0f9f5b;font-size:23rpx;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.last-line{margin-top:10rpx;color:#687380;font-size:24rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.side{display:flex;flex-direction:column;align-items:flex-end;gap:12rpx}.status-tag{padding:6rpx 14rpx;color:#12a05b;background:#eaf8ef;border-radius:999rpx;font-size:22rpx;font-weight:800;white-space:nowrap}.badge{min-width:34rpx;height:34rpx;line-height:34rpx;padding:0 7rpx;text-align:center;color:#fff;background:#f04438;border-radius:999rpx;font-size:20rpx;font-weight:800}
