<view class="page message-page">
  <view wx:if="{{conversations.length}}" class="conversation-list">
    <view wx:for="{{conversations}}" wx:key="id" class="conversation-card {{item.is_service ? 'service' : ''}}" data-index="{{index}}" bindtap="goChat">
      <image class="avatar" src="{{item.avatar_url}}" mode="aspectFill"></image>
      <view class="main">
        <view class="row-top"><view class="nickname">{{item.display_name}}</view><text class="time">{{item.display_time}}</text></view>
        <view class="product-line"><text>{{item.display_status}}</text><text>{{item.display_product}}</text></view>
        <view class="last">{{item.display_message}}</view>
      </view>
      <image wx:if="{{!item.is_service && item.product_cover_url}}" class="product-thumb" src="{{item.product_cover_url}}" mode="aspectFill"></image>
      <view wx:if="{{item.unread_count}}" class="badge">{{item.unread_count}}</view>
    </view>
  </view>
  <empty-state wx:else title="暂无消息"></empty-state>
</view>
