<view class="page message-page">
  <view wx:if="{{conversations.length}}" class="conversation-list">
    <view wx:for="{{conversations}}" wx:key="id" class="conversation-card {{item.service ? 'service-card' : ''}}" data-index="{{index}}" bindtap="goChat">
      <image class="avatar" src="{{item.other_user.avatar || '/assets/tabbar/mine.png'}}" mode="aspectFill"></image>
      <view class="main">
        <view class="top-line"><view class="name">{{item.display_name}}</view><text class="time">{{item.display_time}}</text></view>
        <view class="product-line">{{item.display_product}}</view>
        <view class="last-line">{{item.display_message}}</view>
      </view>
      <view class="side"><view class="status-tag">{{item.display_status}}</view><view wx:if="{{item.unread_count}}" class="badge">{{item.unread_count}}</view></view>
    </view>
  </view>
  <empty-state wx:else title="暂无消息"></empty-state>
</view>
