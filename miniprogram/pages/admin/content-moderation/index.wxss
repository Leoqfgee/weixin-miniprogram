.admin-moderation-page {
  padding-bottom: 80rpx;
}

.help {
  margin-bottom: 18rpx;
  line-height: 1.6;
}

.word-input {
  box-sizing: border-box;
  width: 100%;
  height: 180rpx;
  padding: 18rpx;
  background: #f6f8fa;
  border: 1rpx solid #e4ebe7;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 12rpx 0 18rpx;
}

.chip {
  padding: 12rpx 18rpx;
  color: #526070;
  background: #f3f6f5;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.chip.active {
  color: #fff;
  background: #16a06a;
  font-weight: 800;
}

.add-btn {
  margin-top: 8rpx;
}

.word-row,
.record-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf0f2;
}

.word-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.word-main {
  flex: 1;
  min-width: 0;
}

.actions {
  display: flex;
  gap: 10rpx;
}

.actions button {
  width: 116rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  font-size: 22rpx;
}
