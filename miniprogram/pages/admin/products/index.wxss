.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.small {
  font-size: 30rpx;
}

.desc {
  margin-top: 16rpx;
  color: #334e68;
  line-height: 1.6;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.actions button {
  flex: 1;
  font-size: 26rpx;
}

.danger {
  color: #a61b1b;
  border-color: #a61b1b;
}

.refresh {
  margin-top: 24rpx;
}
