<view class="page">
  <view wx:if="{{products.length}}" class="list">
    <view wx:for="{{products}}" wx:key="id" class="panel item">
      <view class="title small">{{item.title}}</view>
      <view class="muted">卖家：{{item.seller.nickname}} · ¥{{item.price}}</view>
      <view class="desc">{{item.description}}</view>
      <view class="actions">
        <button class="ghost-btn danger" data-id="{{item.id}}" bindtap="offShelf">下架</button>
      </view>
    </view>
  </view>
  <empty-state wx:else title="暂无在售商品"></empty-state>
  <button class="ghost-btn refresh" bindtap="loadProducts">刷新在售商品</button>
</view>
