<view class="page">
  <view class="panel">
    <view class="title">申诉仲裁</view>
    <view class="tabs">
      <button class="{{status === 'pending' ? 'primary-btn' : 'ghost-btn'}}" bindtap="setPending">待处理</button>
      <button class="{{status === '' ? 'primary-btn' : 'ghost-btn'}}" bindtap="setAll">全部</button>
    </view>
  </view>

  <view wx:for="{{appeals}}" wx:key="id" class="panel appeal">
    <view class="row">
      <view class="title small">{{item.reason || '平台介入申请'}}</view>
      <status-badge type="order" status="{{item.order.status}}"></status-badge>
    </view>
    <view class="muted">申诉状态：{{item.status_text}} · 订单号：{{item.order.order_no}}</view>
    <view class="section-title">商品快照</view>
    <view>{{item.product_title}}</view>
    <view class="muted">价格 ￥{{item.product_price}}</view>

    <view class="section-title">支付与担保</view>
    <view class="muted">支付：{{item.payment.status || '无'}} · 担保：{{item.escrow.status || '无'}}</view>

    <view class="section-title">交付记录</view>
    <view class="muted">{{item.delivery_text}} · {{item.delivery_location}}</view>

    <view class="section-title">退款信息</view>
    <view class="muted">原因：{{item.refund.reason}} · 状态：{{item.refund.status_text || '待处理'}}</view>
    <view class="image-grid">
      <image wx:for="{{item.refund.evidence_images}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
    </view>

    <view class="section-title">申诉凭证</view>
    <view class="muted">{{item.description || '无补充说明'}}</view>
    <view class="image-grid">
      <image wx:for="{{item.evidence_images}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
    </view>

    <view wx:if="{{item.status === 'pending'}}" class="actions">
      <button class="primary-btn" data-id="{{item.id}}" data-action="refund" bindtap="arbitrate">支持买家退款</button>
      <button class="ghost-btn" data-id="{{item.id}}" data-action="reject_refund" bindtap="arbitrate">支持卖家</button>
      <button class="ghost-btn" data-id="{{item.id}}" data-action="partial_refund" bindtap="arbitrate">部分退款</button>
    </view>
    <view wx:else class="muted">处理结果：{{item.admin_result_text || item.status_text || '已处理'}}</view>
  </view>

  <empty-state wx:if="{{appeals.length === 0}}" text="暂无申诉"></empty-state>
</view>
