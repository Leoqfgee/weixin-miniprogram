.admin-verification-page {
  padding: 0;
  min-height: 100vh;
  background: #f5f8f6;
}

/* 标签切换 */
.tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #e8f0ea;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #65717c;
  background: #f5f8f6;
  border-radius: 999rpx;
}

.tab-item.active {
  color: #fff;
  background: #16b77a;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: #ef4444;
  border-radius: 999rpx;
}

.tab-item.active .badge {
  background: rgba(255, 255, 255, 0.3);
}

/* 列表区域 */
.list-section {
  padding: 24rpx;
}

.application-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.application-item {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8f0ea;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.application-item.selected {
  border-color: #16b77a;
  background: #eaf8f0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #17212b;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #fff;
}

.status-tag.pending {
  background: #f59e0b;
}

.status-tag.approved {
  background: #16b77a;
}

.status-tag.verified {
  background: #16b77a;
}

.status-tag.rejected {
  background: #ef4444;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-text {
  font-size: 24rpx;
  color: #65717c;
}

.item-extra {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e8f0ea;
}

.extra-label {
  font-size: 24rpx;
  color: #65717c;
}

.extra-value {
  font-size: 24rpx;
  color: #17212b;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #e8f0ea;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #17212b;
}

.close-btn {
  font-size: 36rpx;
  color: #65717c;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 30rpx;
}

.detail-section {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #17212b;
  margin-bottom: 12rpx;
}

.user-info-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #f5f8f6;
  border-radius: 12rpx;
}

.user-info-card .user-name {
  font-size: 28rpx;
  font-weight: 700;
}

.user-credit {
  font-size: 24rpx;
  color: #65717c;
}

.view-profile {
  font-size: 24rpx;
  color: #16b77a;
}

.info-row {
  display: flex;
  margin-top: 12rpx;
}

.info-row .label {
  font-size: 24rpx;
  color: #65717c;
  min-width: 100rpx;
}

.info-row .value {
  font-size: 24rpx;
  color: #17212b;
}

/* 图片展示 */
.image-grid {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.image-grid.single {
  justify-content: flex-start;
}

.image-item {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f8f6;
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 审核备注 */
.note-input {
  width: 100%;
  height: 120rpx;
  padding: 16rpx;
  background: #f5f8f6;
  border: 1rpx solid #e8f0ea;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.note-display {
  padding: 16rpx;
  background: #f5f8f6;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #17212b;
}

.no-note {
  color: #9ca3af;
}

/* 操作按钮 */
.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #e8f0ea;
}

.modal-footer.single {
  justify-content: center;
}

.reject-btn {
  flex: 1;
  height: 72rpx;
  line-height: 70rpx;
  background: #fff;
  color: #ef4444;
  border: 1rpx solid #ef4444;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.approve-btn {
  flex: 1;
  height: 72rpx;
  line-height: 70rpx;
  background: #16b77a;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.close-btn-footer {
  flex: 1;
  height: 72rpx;
  line-height: 70rpx;
  background: #f5f8f6;
  color: #65717c;
  border-radius: 999rpx;
  font-size: 28rpx;
}
