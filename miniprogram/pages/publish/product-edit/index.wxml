<view class="page publish-page">
  <view class="panel image-panel">
    <view class="panel-head"><view class="block-title">商品图片</view><text>{{form.images.length}}/9</text></view>
    <scroll-view scroll-x class="image-scroll"><view class="image-row">
      <view wx:for="{{form.images}}" wx:key="*this" class="image-wrap"><image src="{{item}}" mode="aspectFill"></image><text data-index="{{index}}" bindtap="removeImage">×</text></view>
      <view wx:if="{{form.images.length < 9}}" class="image-add" bindtap="chooseImages"><view>+</view><text>添加图片</text></view>
    </view></scroll-view>
  </view>

  <view class="panel form-panel">
    <view class="block-title">商品标题</view>
    <input class="title-input" value="{{form.title}}" data-field="title" bindinput="setField" maxlength="40" placeholder="请简明描述商品名称" />
    <view class="ai-actions"><button class="ai-btn" bindtap="useAiTitle"><text>AI</text> 标题建议</button></view>
  </view>

  <view class="panel form-panel">
    <view class="block-title">商品描述</view>
    <textarea value="{{form.description}}" data-field="description" bindinput="setField" maxlength="1000" placeholder="请详细描述品牌、型号、功能、使用情况等"></textarea>
    <view class="ai-actions"><button class="ai-btn" bindtap="useAiDescription"><text>AI</text> 润色描述</button></view>
  </view>

  <view class="panel form-panel price-panel">
    <view class="block-title">价格</view>
    <view class="price-input-row"><text>￥</text><input type="digit" value="{{form.price}}" data-field="price" bindinput="setField" placeholder="请输入售价" /></view>
  </view>

  <view class="option-grid">
    <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange"><view class="option-card"><view class="option-icon icon-category"></view><view><view class="text-strong">商品分类</view><view class="muted">{{selectedCategoryText}}</view></view><view class="chevron"></view></view></picker>
    <picker mode="selector" range="{{conditionOptions}}" range-key="label" bindchange="onConditionChange"><view class="option-card"><view class="option-icon warm icon-condition"></view><view><view class="text-strong">商品成色</view><view class="muted">{{selectedConditionText}}</view></view><view class="chevron"></view></view></picker>
  </view>

  <view class="panel form-panel trade-panel">
    <view class="block-title">交易校区</view>
    <view class="campus-row campus-choice-row">
      <text>所在校区</text>
      <view class="campus-choice-group">
        <view wx:for="{{campusOptions}}" wx:key="value" class="campus-choice {{index === campusIndex ? 'active' : ''}}" data-index="{{index}}" bindtap="onCampusTap">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-actions"><button class="ghost-btn" data-action="draft" bindtap="submit">保存修改</button><button wx:if="{{canSubmitReview}}" class="primary-btn" data-action="review" bindtap="submit">提交审核</button></view>
</view>
