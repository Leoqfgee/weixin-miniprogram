<view class="page publish-page">
  <view class="publish-banner">校园二手 · 真实可靠 · 提交后等待审核</view>
  <view class="panel image-panel"><view class="panel-head"><view class="block-title">商品图片</view><text>{{form.images.length}}/9</text></view><scroll-view scroll-x class="image-scroll"><view class="image-row"><view wx:for="{{form.images}}" wx:key="*this" class="image-wrap"><image src="{{item}}" mode="aspectFill"></image><text data-index="{{index}}" bindtap="removeImage">×</text></view><view wx:if="{{form.images.length < 9}}" class="image-add" bindtap="chooseImages"><view>＋</view><text>添加图片</text></view></view></scroll-view></view>
  <view class="panel form-panel"><view class="block-title">商品标题</view><input value="{{form.title}}" data-field="title" bindinput="setField" maxlength="40" placeholder="请简明扼要地描述商品名称" /><button class="ai-btn" bindtap="useAiTitle">标题建议</button></view>
  <view class="panel form-panel"><view class="block-title">商品描述</view><textarea value="{{form.description}}" data-field="description" bindinput="setField" maxlength="1000" placeholder="请详细描述品牌、型号、功能、使用情况等信息"></textarea><button class="ai-btn" bindtap="useAiDescription">润色描述</button></view>
  <view class="panel form-panel price-panel"><view class="block-title">价格</view><view class="price-input"><text>￥</text><input type="digit" value="{{form.price}}" data-field="price" bindinput="setField" placeholder="请输入售价" /></view></view>
  <view class="option-grid"><picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange"><view class="option-card"><view><view class="text-strong">商品分类</view><view class="muted">{{categoryIndex >= 0 ? categories[categoryIndex].name : autoCategoryText}}</view></view><text>›</text></view></picker><picker mode="selector" range="{{conditionOptions}}" range-key="label" bindchange="onConditionChange"><view class="option-card"><view><view class="text-strong">商品成色</view><view class="muted">{{conditionOptions[conditionIndex].label}}</view></view><text>›</text></view></picker></view>
  <view class="panel form-panel"><view class="block-title">交易方式 / 校区</view><input value="{{form.campus}}" data-field="campus" bindinput="setField" placeholder="请输入校区或取货地点" /><checkbox-group class="delivery-group" bindchange="onDeliveryChange"><label wx:for="{{deliveryOptions}}" wx:key="value" class="delivery-item"><checkbox value="{{item.value}}" checked="{{form.delivery_options.indexOf(item.value) >= 0}}" color="#16b85e" />{{item.label}}</label></checkbox-group></view>
  <view class="bottom-actions"><button wx:if="{{editingOnSale}}" class="primary-btn" data-action="draft" bindtap="submit">保存修改</button><button wx:else class="ghost-btn" data-action="draft" bindtap="submit">保存草稿</button><button wx:if="{{!editingOnSale}}" class="primary-btn" data-action="review" bindtap="submit">提交审核</button></view>
</view>
