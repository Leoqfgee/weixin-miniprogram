<view class="page publish-page">
  <view class="title">{{productId ? '编辑发布' : '发布闲置'}}</view>
  <view class="muted intro">{{editingOnSale ? '修改保存后立即更新在售商品信息' : '真实描述更容易成交，草稿可稍后继续完善'}}</view>

  <view class="image-grid">
    <view wx:for="{{form.images}}" wx:key="*this" class="image-wrap">
      <image src="{{item}}" mode="aspectFill"></image>
      <text data-index="{{index}}" bindtap="removeImage">×</text>
    </view>
    <view wx:if="{{form.images.length < 9}}" class="image-add" bindtap="chooseImages">＋<text>添加图片</text></view>
  </view>

  <view class="panel form-panel">
    <input class="title-input" value="{{form.title}}" data-field="title" bindinput="setField" maxlength="40" placeholder="标题：品牌、型号或关键词" />
    <textarea value="{{form.description}}" data-field="description" bindinput="setField" maxlength="1000" placeholder="描述成色、购买时间、使用情况、配件和瑕疵"></textarea>
    <view class="ai-actions">
      <button class="ai-btn" bindtap="useAiTitle">AI 标题建议</button>
      <button class="ai-btn" bindtap="useAiDescription">AI 润色描述</button>
    </view>
  </view>

  <view class="panel option-panel">
    <view class="row"><text>价格</text><input type="digit" value="{{form.price}}" data-field="price" bindinput="setField" placeholder="¥ 0.00" /></view>
    <view class="row"><text>库存</text><input type="number" value="{{form.stock}}" data-field="stock" bindinput="setField" /></view>
    <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
      <view class="row"><text>分类</text><text class="muted">{{categoryIndex >= 0 ? categories[categoryIndex].name : '请选择'}}</text></view>
    </picker>
    <picker mode="selector" range="{{conditionOptions}}" range-key="label" bindchange="onConditionChange">
      <view class="row"><text>成色（选填）</text><text class="muted">{{conditionOptions[conditionIndex].label}}</text></view>
    </picker>
  </view>

  <view class="bottom-actions">
    <button wx:if="{{editingOnSale}}" class="primary-btn" data-action="draft" bindtap="submit">保存修改</button>
    <button wx:else class="ghost-btn" data-action="draft" bindtap="submit">保存草稿</button>
    <button wx:if="{{!editingOnSale}}" class="primary-btn" data-action="review" bindtap="submit">提交审核</button>
  </view>
</view>
