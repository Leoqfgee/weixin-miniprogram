<view class="page publish-page">
  <view class="publish-banner"><view class="banner-title">校园二手  ·  真实可靠  ·  安全交易</view></view>

  <view class="panel image-panel">
    <view class="panel-head"><view class="block-title">商品图片</view><text>{{form.images.length}}/9</text></view>
    <scroll-view scroll-x class="image-scroll"><view class="image-row">
      <view wx:for="{{form.images}}" wx:key="*this" class="image-wrap"><image src="{{item}}" mode="aspectFill"></image><text data-index="{{index}}" bindtap="removeImage">x</text></view>
      <view wx:if="{{form.images.length < 9}}" class="image-add" bindtap="chooseImages"><view>+</view><text>添加图片</text></view>
    </view></scroll-view>
  </view>

  <view class="panel form-panel">
    <view class="block-title">商品标题</view>
    <input class="title-input" value="{{form.title}}" data-field="title" bindinput="setField" maxlength="40" placeholder="请简明描述商品名称" />
    <view class="ai-actions"><button class="ai-btn" bindtap="useAiTitle"><text>AI</text> 标题建议</button></view>
  </view>

  <view class="panel form-panel">
    <view class="block-title">商品描述</view>
    <textarea value="{{form.description}}" data-field="description" bindinput="setField" maxlength="1000" placeholder="请详细描述品牌、型号、功能、使用情况等"></textarea>
    <view class="ai-actions single"><button class="ai-btn" bindtap="useAiDescription"><text>AI</text> 润色描述</button></view>
  </view>

  <view class="panel form-panel price-panel">
    <view class="block-title">价格 *</view>
    <view class="price-input-row"><text>&#65509;</text><input type="digit" value="{{form.price}}" data-field="price" bindinput="setField" placeholder="请输入售价" /></view>
  </view>

  <view class="option-grid">
    <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange"><view class="option-card"><view class="option-icon">+</view><view><view class="text-strong">商品分类</view><view class="muted">{{categoryIndex >= 0 ? categories[categoryIndex].name : autoCategoryText}}</view></view><view class="chevron">&gt;</view></view></picker>
    <picker mode="selector" range="{{conditionOptions}}" range-key="label" bindchange="onConditionChange"><view class="option-card"><view class="option-icon warm">?</view><view><view class="text-strong">商品成色</view><view class="muted">{{conditionOptions[conditionIndex].label}}</view></view><view class="chevron">&gt;</view></view></picker>
  </view>

  <view class="panel form-panel trade-panel">
    <view class="block-title">交易方式 / 校区</view>
    <view class="campus-row"><text>所在校区</text><input value="{{form.campus}}" data-field="campus" bindinput="setField" placeholder="请填写校区" /></view>
    <view class="muted trade-note">支持校内面交或快递，下单后可在订单中确认时间和地点</view>
  </view>

  <view class="agreement">提交后等待平台审核，通过后将展示给买家</view>
  <view class="bottom-actions"><button wx:if="{{editingOnSale}}" class="primary-btn" data-action="draft" bindtap="submit">保存修改</button><button wx:else class="ghost-btn" data-action="draft" bindtap="submit">保存草稿</button><button wx:if="{{!editingOnSale}}" class="primary-btn" data-action="review" bindtap="submit">提交审核</button></view>
</view>
