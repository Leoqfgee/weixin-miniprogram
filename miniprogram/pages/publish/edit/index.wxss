.publish-page {
  padding: 18rpx 24rpx 156rpx;
  background: #f6f8f6;
}

.page-title {
  text-align: center;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 900;
}

.publish-banner {
  position: relative;
  margin: 8rpx -24rpx 18rpx;
  padding: 16rpx 30rpx;
  overflow: hidden;
  text-align: center;
  background: #edf8f1;
  border-radius: 0;
}

.banner-title {
  color: #11924f;
  font-size: 23rpx;
  font-weight: 700;
}

.panel {
  margin-bottom: 20rpx;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.panel-head text {
  color: #7a8491;
}

.image-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.image-row {
  display: flex;
  gap: 18rpx;
}

.image-wrap,
.image-add {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  flex: 0 0 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-wrap image {
  width: 100%;
  height: 100%;
}

.image-wrap text {
  position: absolute;
  right: 6rpx;
  top: 6rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  text-align: center;
  color: #fff;
  background: rgba(31, 41, 51, 0.55);
  border-radius: 50%;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #16a45a;
  background: #f6fbf7;
  border: 2rpx dashed #c9d8d0;
}

.image-add view {
  font-size: 52rpx;
  line-height: 1;
}

.image-add text {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.tip {
  margin-top: 18rpx;
}

.title-input {
  margin-top: 18rpx;
}

.form-panel textarea {
  margin-top: 18rpx;
}

.ai-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.ai-actions.single {
  margin-top: 16rpx;
}

.ai-btn {
  height: 64rpx;
  line-height: 62rpx;
  margin: 0;
  padding: 0 12rpx;
  color: #11924f;
  background: #ffffff;
  border: 1rpx solid #16b85e;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.ai-btn text {
  padding: 3rpx 8rpx;
  margin-right: 6rpx;
  color: #16b85e;
  border: 2rpx solid #16b85e;
  border-radius: 50%;
}

.ai-btn view {
  margin-top: 8rpx;
  color: #7a8491;
  font-size: 22rpx;
  font-weight: 400;
}

.two-grid,
.option-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.mini-panel {
  padding: 22rpx;
}

.mini-panel input {
  margin-top: 18rpx;
}

.mini-panel .muted {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.option-grid {
  margin-top: 20rpx;
}

.option-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 104rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e8ece8;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.05);
}

.option-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  color: #16a45a;
  background: #eaf8ef;
  border-radius: 18rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.option-icon.warm {
  color: #d98916;
  background: #fff3d8;
}

.text-strong text {
  color: #7a8491;
  font-size: 22rpx;
  font-weight: 400;
}

.chevron {
  margin-left: auto;
  color: #9aa2ad;
  font-size: 42rpx;
}

.agreement {
  margin: 26rpx 0 6rpx;
  color: #16a45a;
  font-size: 24rpx;
}

.bottom-actions {
  position: fixed;
  z-index: 5;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 16rpx;
  padding: 18rpx 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.96);
}

.bottom-actions button {
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 10rpx;
}
