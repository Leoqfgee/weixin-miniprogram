.publish-page{padding:18rpx 24rpx 170rpx;background:#f6f8f6}.publish-banner{margin:-4rpx -24rpx 18rpx;padding:16rpx 30rpx;text-align:center;color:#11924f;background:#edf8f1;font-size:23rpx;font-weight:700}.panel{margin-bottom:20rpx;padding:24rpx;background:#fff;border:1rpx solid #e8ece8;border-radius:14rpx;box-shadow:0 10rpx 24rpx rgba(31,41,51,.05)}.panel-head{display:flex;justify-content:space-between;align-items:center}.panel-head text{color:#7a8491}.block-title{color:#1f2933;font-size:28rpx;font-weight:900}.image-scroll{margin-top:20rpx;white-space:nowrap}.image-row{display:flex;gap:18rpx}.image-wrap,.image-add{position:relative;width:150rpx;height:150rpx;flex:0 0 150rpx;border-radius:12rpx;overflow:hidden}.image-wrap image{width:100%;height:100%}.image-wrap text{position:absolute;right:6rpx;top:6rpx;width:36rpx;height:36rpx;line-height:34rpx;text-align:center;color:#fff;background:rgba(31,41,51,.55);border-radius:50%}.image-add{display:flex;flex-direction:column;align-items:center;justify-content:center;color:#16a45a;background:#f6fbf7;border:2rpx dashed #c9d8d0}.image-add view{font-size:52rpx;line-height:1}.image-add text{margin-top:8rpx;font-size:22rpx}.form-panel input{height:76rpx;margin-top:16rpx;padding:0 18rpx;background:#fafcfb;border:1rpx solid #e5ece7;border-radius:10rpx}.form-panel textarea{width:100%;height:180rpx;margin-top:16rpx;padding:18rpx;box-sizing:border-box;background:#fafcfb;border:1rpx solid #e5ece7;border-radius:10rpx}.ai-btn{width:100%;height:64rpx;line-height:62rpx;margin:16rpx 0 0;color:#11924f;background:#fff;border:1rpx solid #16b85e;border-radius:10rpx;font-size:24rpx;font-weight:900}.price-input{display:flex;align-items:center;height:76rpx;margin-top:16rpx;padding:0 18rpx;background:#fafcfb;border:1rpx solid #e5ece7;border-radius:10rpx}.price-input text{margin-right:12rpx;color:#1f2933;font-weight:900}.price-input input{flex:1;margin:0;padding:0;border:0;background:transparent}.option-grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx;margin-bottom:20rpx}.option-card{display:flex;align-items:center;justify-content:space-between;min-height:104rpx;padding:22rpx;background:#fff;border:1rpx solid #e8ece8;border-radius:14rpx;box-shadow:0 10rpx 24rpx rgba(31,41,51,.05)}.text-strong{color:#1f2933;font-weight:900}.muted{margin-top:8rpx;color:#7a8491;font-size:23rpx}.option-card>text{color:#9aa2ad;font-size:42rpx}.delivery-group{display:flex;gap:20rpx;margin-top:20rpx}.delivery-item{display:flex;align-items:center;gap:8rpx;color:#2f3742;font-size:25rpx}.bottom-actions{position:fixed;z-index:5;left:0;right:0;bottom:0;display:grid;grid-template-columns:1fr 1.25fr;gap:16rpx;padding:18rpx 24rpx calc(30rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.96);box-shadow:0 -8rpx 24rpx rgba(20,33,45,.08)}.bottom-actions button{height:86rpx;line-height:86rpx;border-radius:10rpx}
