.publish-page {
  padding: 22rpx 22rpx 170rpx;
  background: #f5f8f6;
}
.panel {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #e8f0ea;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 26rpx rgba(31,41,51,.06);
}
.panel-head { display: flex; justify-content: space-between; align-items: center; }
.panel-head text { color: #7a8491; font-size: 24rpx; }
.block-title { color: #16202a; font-size: 30rpx; font-weight: 900; }
.block-title::before { content: ''; display: inline-block; width: 8rpx; height: 28rpx; margin-right: 12rpx; vertical-align: -5rpx; background: #18b86c; border-radius: 999rpx; }
.image-scroll { margin-top: 20rpx; white-space: nowrap; }
.image-row { display: flex; gap: 16rpx; }
.image-wrap, .image-add { position: relative; flex: 0 0 156rpx; width: 156rpx; height: 156rpx; border-radius: 16rpx; overflow: hidden; }
.image-wrap image { width: 100%; height: 100%; }
.image-wrap text { position: absolute; right: 8rpx; top: 8rpx; width: 34rpx; height: 34rpx; line-height: 32rpx; text-align: center; color: #fff; background: rgba(31,41,51,.55); border-radius: 50%; }
.image-add { display: flex; flex-direction: column; align-items: center; justify-content: center; color: #16a45a; background: #f7fcf9; border: 2rpx dashed #c9d8d0; }
.image-add view { font-size: 54rpx; line-height: 1; }
.image-add text { margin-top: 8rpx; font-size: 22rpx; }
.title-input, .form-panel textarea { margin-top: 18rpx; }
.form-panel textarea { min-height: 220rpx; }
.ai-actions { margin-top: 18rpx; }
.ai-btn { height: 68rpx; line-height: 66rpx; margin: 0; padding: 0 16rpx; color: #0f9f5b; background: #f7fffa; border: 1rpx solid #13b86b; border-radius: 999rpx; font-size: 25rpx; font-weight: 900; }
.ai-btn::after { border: 0; }
.ai-btn text { display: inline-flex; align-items: center; justify-content: center; width: 38rpx; height: 38rpx; margin-right: 8rpx; border: 2rpx solid #13b86b; border-radius: 50%; font-size: 22rpx; }
.price-panel { padding: 24rpx; }
.price-input-row, .campus-row { display: flex; align-items: center; gap: 18rpx; margin-top: 18rpx; }
.price-input-row text, .campus-row text { flex: none; color: #16202a; font-size: 28rpx; font-weight: 900; }
.price-input-row input, .campus-row input, .picker-value { flex: 1; min-width: 0; color: #16202a; font-size: 28rpx; text-align: right; }
.campus-choice-row { align-items: flex-start; }
.campus-choice-group { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; min-width: 0; }
.campus-choice { height: 72rpx; line-height: 70rpx; text-align: center; color: #168b5a; background: #f6fffa; border: 2rpx solid #b8e6d0; border-radius: 16rpx; font-size: 27rpx; font-weight: 900; box-sizing: border-box; }
.campus-choice.active { color: #fff; background: #18b86c; border-color: #18b86c; box-shadow: 0 8rpx 18rpx rgba(24,184,108,.22); }
.option-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; margin: 20rpx 0; }
.option-card { display: flex; align-items: center; gap: 16rpx; min-height: 112rpx; padding: 20rpx; background: #fff; border: 1rpx solid #e8f0ea; border-radius: 20rpx; box-shadow: 0 10rpx 24rpx rgba(31,41,51,.05); }
.option-icon { display: flex; align-items: center; justify-content: center; flex: none; width: 56rpx; height: 56rpx; color: #0f9f5b; background: #eaf8f0; border-radius: 18rpx; font-size: 30rpx; font-weight: 900; }
.option-icon.warm { color: #d98916; background: #fff4df; }
.text-strong { color: #16202a; font-size: 27rpx; font-weight: 900; }
.muted { margin-top: 6rpx; color: #7b8794; font-size: 23rpx; }
.chevron { margin-left: auto; width: 16rpx; height: 16rpx; border-top: 3rpx solid #9aa5ad; border-right: 3rpx solid #9aa5ad; transform: rotate(45deg); }
.trade-panel { margin-top: 0; }
.trade-note { margin-top: 16rpx; color: #7b8794; line-height: 1.6; }
.agreement { display: none; }
.bottom-actions { position: fixed; z-index: 10; left: 0; right: 0; bottom: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; padding: 18rpx 22rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,.98); box-shadow: 0 -10rpx 30rpx rgba(31,41,51,.08); }
.bottom-actions button { height: 78rpx; line-height: 76rpx; border-radius: 999rpx; font-size: 28rpx; font-weight: 900; }

.option-icon.icon-category::before { content: ''; width: 28rpx; height: 28rpx; border: 4rpx solid currentColor; border-radius: 8rpx; box-shadow: 20rpx 0 0 -6rpx currentColor, 0 20rpx 0 -6rpx currentColor, 20rpx 20rpx 0 -6rpx currentColor; }
.option-icon.icon-condition::before { content: ''; width: 34rpx; height: 34rpx; border: 5rpx solid currentColor; border-radius: 50%; }
.option-icon.icon-condition::after { content: ''; width: 14rpx; height: 24rpx; border-right: 5rpx solid currentColor; border-bottom: 5rpx solid currentColor; transform: rotate(35deg); position: absolute; }
.option-icon { position: relative; }

/* v4: stable equal bottom buttons */
.bottom-actions {
  display: flex !important;
  align-items: center;
  gap: 18rpx !important;
  padding-left: 24rpx !important;
  padding-right: 24rpx !important;
  box-sizing: border-box;
}
.bottom-actions button {
  flex: 1 1 0 !important;
  width: 0 !important;
  min-width: 0 !important;
  max-width: none !important;
  margin: 0 !important;
  padding: 0 !important;
  box-sizing: border-box !important;
  height: 82rpx !important;
  line-height: 80rpx !important;
  font-size: 28rpx !important;
  text-align: center !important;
}
.bottom-actions button::after { border: 0; }
