.category-page .search-box { position: sticky; top: 0; z-index: 35; }
.category-page .filters { position: sticky; top: 88rpx; z-index: 34; background: rgba(244,247,245,.98); padding: 12rpx 0; }
.category-page {
  padding: 18rpx 18rpx 118rpx;
  background: #f4f7f5;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.06);
}

.search-box input {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  padding: 0 20rpx;
  color: #1f2933;
  background: #f4f7f9;
  border: 1rpx solid #e7edf0;
  border-radius: 8rpx;
  font-size: 25rpx;
}

.search-box button {
  flex: 0 0 178rpx;
  width: 178rpx;
  height: 70rpx;
  line-height: 70rpx;
  margin: 0;
  padding: 0;
  border-radius: 10rpx;
  font-size: 25rpx;
}

.filters {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin: 18rpx 0;
}

.filter {
  box-sizing: border-box;
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 16rpx;
  color: #334e68;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  border-radius: 8rpx;
  font-size: 24rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.more-filters {
  margin-bottom: 22rpx;
  padding: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 51, 0.06);
}

.filter-section-title {
  margin-bottom: 14rpx;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 800;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.field-grid input,
.date-filter {
  box-sizing: border-box;
  width: 100%;
  min-height: 62rpx;
  padding: 0 16rpx;
  color: #334e68;
  background: #f6f8fa;
  border: 1rpx solid #e4ebef;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 62rpx;
}

.apply-btn {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  margin-top: 14rpx;
  padding: 0;
  border-radius: 10rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
