.search-box {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
}

button {
  width: 144rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.filters {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
  flex-wrap: wrap;
}

.filters picker {
  flex: 1;
}

.filter {
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 20rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  border-radius: 8rpx;
  color: #334e68;
}

.more-filters {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.more-filters input,
.date-filter {
  min-height: 64rpx;
  padding: 0 14rpx;
  border: 1rpx solid #e6ebf1;
  border-radius: 8rpx;
  background: #f5f7fa;
  font-size: 24rpx;
  line-height: 64rpx;
}

.more-filters button {
  grid-column: span 3;
  width: 100%;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
