<view class="page">
  <view wx:if="{{items.length}}" class="list">
    <view wx:for="{{items}}" wx:key="product_id" class="panel cart-item">
      <view class="item-title">{{item.product ? item.product.title : '失效商品'}}</view>
      <view class="muted">{{item.valid ? '可购买' : item.invalid_reason}}</view>
      <view class="row">
        <text class="price">￥{{item.product ? item.product.price : 0}}</text>
        <input type="number" value="{{item.quantity}}" data-id="{{item.product_id}}" bindblur="changeQuantity" />
      </view>
      <view class="actions">
        <button class="ghost-btn" data-id="{{item.product_id}}" bindtap="deleteItem">删除</button>
        <button wx:if="{{item.valid}}" class="primary-btn" data-id="{{item.product_id}}" data-quantity="{{item.quantity}}" bindtap="onCheckout">去结算</button>
      </view>
    </view>
  </view>
  <empty-state wx:else title="购物车为空" description="从商品详情页加入想买的物品"></empty-state>
</view>
