<view class="page mine-page">
  <view class="profile-card" bindtap="goProfileHome">
    <view class="profile-top">
      <image wx:if="{{user && (user.profile.avatar || user.profile.avatar_url)}}" class="avatar" src="{{user.profile.avatar || user.profile.avatar_url}}" mode="aspectFill"></image>
      <view wx:else class="avatar placeholder">{{avatarText}}</view>
      <view class="profile-main">
        <view class="name-line">{{user ? user.profile.nickname : '未登录'}}</view>
        <view class="campus-line">{{user ? (user.profile.campus || '未填写校区') : '请先登录'}}</view>
        <view wx:if="{{user}}" class="profile-tags">
          <text catchtap="goCredit">信用分 {{creditScore}} · {{creditLevel}}</text>
        </view>
      </view>
      <button wx:if="{{!user}}" class="primary-btn action" catchtap="goLogin">去登录</button>
      <button wx:else class="ghost-btn action" catchtap="goProfileEdit">编辑资料</button>
    </view>
    <view wx:if="{{user}}" class="stats">
      <view><text>{{stats.published}}</text><text>发布商品</text></view>
      <view><text>{{stats.bought}}</text><text>买到的</text></view>
      <view><text>{{stats.sold}}</text><text>卖出的</text></view>
      <view><text>{{stats.favorites}}</text><text>收藏</text></view>
    </view>
  </view>

  <view wx:if="{{user}}" class="panel grid-panel">
    <view class="section-title">我的交易</view>
    <view class="service-grid trade-grid">
      <view class="service-item" bindtap="goPublished"><image class="service-icon-img" src="/assets/icons/my-published.png" mode="aspectFit"></image><view>我发布的</view></view>
      <view class="service-item" bindtap="goBought"><image class="service-icon-img" src="/assets/icons/my-bought.png" mode="aspectFit"></image><view>我买到的</view></view>
      <view class="service-item" bindtap="goSold"><image class="service-icon-img" src="/assets/icons/my-sold.png" mode="aspectFit"></image><view>我卖出的</view></view>
    </view>
  </view>

  <view wx:if="{{user}}" class="panel grid-panel">
    <view class="section-title">我的服务</view>
    <view class="service-grid">
      <view class="service-item" bindtap="goCredit"><image class="service-icon-img" src="/assets/icons/my-service.png" mode="aspectFit"></image><view>信用分详情</view></view>
      <view class="service-item" bindtap="goStudentVerification"><image class="service-icon-img" src="/assets/icons/my-service.png" mode="aspectFit"></image><view>学生认证</view></view>
      <view class="service-item" bindtap="goFavorites"><image class="service-icon-img" src="/assets/icons/my-favorite.png" mode="aspectFit"></image><view>我的收藏</view></view>
      <view class="service-item" bindtap="goAddresses"><image class="service-icon-img" src="/assets/icons/my-address.png" mode="aspectFit"></image><view>收货地址</view></view>
      <view class="service-item" bindtap="goRefunds"><image class="service-icon-img" src="/assets/icons/my-refund.png" mode="aspectFit"></image><view>售后</view></view>
      <view class="service-item" bindtap="goCustomerService"><image class="service-icon-img" src="/assets/icons/my-service.png" mode="aspectFit"></image><view>联系客服</view></view>
      <view class="service-item" bindtap="goProfileHome"><image class="service-icon-img" src="/assets/icons/my-home.png" mode="aspectFit"></image><view>我的主页</view></view>
      <view class="service-item" bindtap="goSettings"><image class="service-icon-img" src="/assets/icons/my-setting.png" mode="aspectFit"></image><view>设置</view></view>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="panel admin-panel">
    <view class="section-title">管理员工具</view>
    <view class="admin-entry" bindtap="goAdminReportHandle"><view class="title small">举报处理</view><view class="muted">处理待处理举报、扣分和商品下架</view></view>
    <view class="admin-entry" bindtap="goAdminStudentVerification"><view class="title small">学生认证审核</view><view class="muted">审核学生证照片和认证资料</view></view>
    <view class="admin-entry" bindtap="goAdminContentModeration"><view class="title small">违禁词管理</view><view class="muted">维护词库并查看内容拦截记录</view></view>
    <view class="admin-entry" bindtap="goAdminCreditAdjust"><view class="title small">调整信用分</view><view class="muted">搜索用户、加分扣分并写入流水</view></view>
    <view class="admin-entry" bindtap="goRefunds"><view class="title small">售后退款单</view><view class="muted">查看和跟进平台售后申请</view></view>
    <view class="admin-entry" bindtap="goAdminAppeals"><view class="title small">申诉仲裁</view><view class="muted">处理平台介入申请</view></view>
    <view class="admin-entry" bindtap="goAdminReports"><view class="title small">统计报表</view><view class="muted">查看发布、成交和活跃数据</view></view>
    <view class="admin-entry" bindtap="goAdminLogs"><view class="title small">后台日志</view><view class="muted">查看操作日志和基础统计</view></view>
  </view>
  <button wx:if="{{user}}" class="logout" bindtap="logout">退出登录</button>
</view>
