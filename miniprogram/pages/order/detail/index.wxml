<view class="page order-detail-page green-page"><view wx:if="{{order}}" class="order-wrap"><view class="status-hero"><view class="role-tag">{{order.role_text}}</view><view class="status-title">{{order.status_tip}}</view><view class="status-sub">当前状态：{{order.status_text}}</view></view><view class="panel steps-panel"><view class="steps"><view wx:for="{{steps}}" wx:key="key" class="step {{index <= currentStep ? 'active' : ''}}"><view class="dot">{{index + 1}}</view><text>{{item.text}}</text></view></view></view><view class="panel amount-panel"><view><view class="muted">订单金额</view><view class="amount">{{order.total_amount_text}}</view></view><view class="order-meta"><view>创建时间：{{order.created_text}}</view><view>资金状态：{{fundText}}</view></view></view><view class="panel"><view class="block-title">商品信息</view><view wx:for="{{order.items}}" wx:key="id" class="product-line"><image wx:if="{{item.snapshot.cover_image}}" src="{{item.snapshot.cover_image}}" mode="aspectFill" class="thumb"></image><view wx:else class="thumb placeholder">图</view><view class="product-info"><view class="text-strong">{{item.snapshot.title}}</view><view class="muted">数量 {{item.quantity}} · 成色 {{item.snapshot.condition_text}} · 单价 {{item.unit_price_text}}</view><view wx:if="{{item.snapshot.description}}" class="snapshot-desc">{{item.snapshot.description}}</view></view></view></view><view class="panel"><view class="block-title">{{order.current_role === 'buyer' ? '卖家信息' : '买家信息'}}</view><view class="contact-row"><image class="contact-avatar" src="{{order.contact_user.avatar || '/assets/tabbar/mine.png'}}" mode="aspectFill"></image><view class="contact-main"><view class="text-strong">{{order.contact_user.nickname}}</view><view class="muted">校区：{{order.contact_user.campus}}</view><view class="muted">手机号：{{order.contact_user.phone_masked}}</view></view><button class="ghost-btn contact-btn" bindtap="contactCounterparty">{{order.contact_label}}</button></view></view><view class="panel"><view class="block-title">交易信息</view><view wx:if="{{order.delivery}}" class="kv"><text>交易方式</text><view>{{order.delivery.delivery_type_text}}</view></view><view wx:if="{{order.delivery}}" class="kv"><text>见面地点</text><view>{{order.delivery.location_text}}</view></view><view wx:if="{{order.shipping_address}}" class="kv"><text>收货地址</text><view>{{order.shipping_address.name}} {{order.shipping_address.phone}}<view class="muted">{{order.shipping_address.address}}</view></view></view><view wx:if="{{!order.shipping_address && !order.delivery}}" class="muted">暂无交易信息</view></view><view class="panel"><view class="block-title">售后服务</view><view wx:if="{{order.refund}}" class="kv"><text>售后状态</text><view>{{order.refund.status_text || '处理中'}}</view></view><view wx:else class="kv"><text>售后状态</text><view>暂无售后</view></view></view><view class="actions"><button wx:if="{{actionMap.pay || actionMap.can_pay}}" class="primary-btn" bindtap="pay">去付款</button><button wx:if="{{actionMap.cancel_order}}" class="ghost-btn" bindtap="cancel">取消订单</button><button wx:if="{{actionMap.contact_seller || actionMap.contact_buyer}}" class="ghost-btn" bindtap="contactCounterparty">{{order.contact_label}}</button><button wx:if="{{actionMap.seller_cancel_and_refund || actionMap.can_seller_cancel_and_refund}}" class="ghost-btn" bindtap="sellerCancel">取消并退款</button><button wx:if="{{actionMap.seller_deliver || actionMap.can_seller_deliver}}" class="primary-btn" bindtap="sellerDeliver">去发货</button><button wx:if="{{actionMap.confirm_receive || actionMap.can_confirm_receipt}}" class="primary-btn" bindtap="confirmReceipt">确认收货</button><button wx:if="{{actionMap.reject_receive}}" class="ghost-btn" bindtap="rejectReceive">拒绝收货</button><button wx:if="{{actionMap.create_review}}" class="ghost-btn" bindtap="review">评价</button><button wx:if="{{actionMap.apply_refund || actionMap.apply_after_sale || actionMap.can_apply_refund}}" class="ghost-btn" bindtap="applyRefund">申请售后</button><button wx:if="{{actionMap.apply_appeal}}" class="ghost-btn" bindtap="applyAppeal">平台介入</button><button wx:if="{{actionMap.view_refund || actionMap.view_refund_result || order.status === 'refunding' || order.status === 'refunded'}}" class="ghost-btn" bindtap="viewRefund">查看售后</button></view></view><view wx:else class="panel muted">正在加载订单...</view></view>
