<view class="page order-detail-page">
  <view wx:if="{{order}}" class="order-wrap">
    <view class="status-hero">
      <view class="role-tag">{{order.current_role === 'buyer' ? '我买到的' : '我卖出的'}}</view>
      <view class="status-title">{{order.status_text || '订单详情'}}</view>
      <view class="status-tip">{{order.status_tip || fundText}}</view>
    </view>

    <view class="panel">
      <view class="steps">
        <view wx:for="{{steps}}" wx:key="key" class="step {{index <= currentStep ? 'active' : ''}}">
          <view class="dot"></view>
          <text>{{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="panel amount-panel">
      <view>
        <view class="muted">订单金额</view>
        <view class="amount">￥{{order.total_amount}}</view>
      </view>
      <view class="order-meta">
        <view>订单编号：{{order.order_no}}</view>
        <view>创建时间：{{order.created_at}}</view>
      </view>
    </view>

    <view class="panel">
      <view class="block-title">商品信息</view>
      <view wx:for="{{order.items}}" wx:key="id" class="product-line">
        <image wx:if="{{item.product_snapshot.cover_image}}" src="{{item.product_snapshot.cover_image}}" mode="aspectFill" class="thumb"></image>
        <view wx:else class="thumb placeholder">图</view>
        <view class="product-info">
          <view class="text-strong">{{item.product_snapshot.title}}</view>
          <view class="muted">数量 {{item.quantity}} · 成色 {{item.product_snapshot.condition || '未填写'}} · 单价 ￥{{item.unit_price}}</view>
          <view wx:if="{{item.product_snapshot.description}}" class="snapshot-desc">{{item.product_snapshot.description}}</view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="block-title">{{order.current_role === 'buyer' ? '卖家信息' : '买家信息'}}</view>
      <view class="contact-row">
        <image class="contact-avatar" src="{{order.contact_user.avatar || '/assets/tabbar/mine.png'}}" mode="aspectFill"></image>
        <view class="contact-main">
          <view class="text-strong">{{order.contact_user.nickname || '校园同学'}}</view>
          <view class="muted">手机号：{{order.contact_user.phone_masked || '未留手机号'}}</view>
          <view class="muted">校区：{{order.contact_user.campus || '未填写'}}</view>
        </view>
        <button class="ghost-btn contact-btn" bindtap="contactCounterparty">{{order.contact_label}}</button>
      </view>
    </view>

    <view class="panel">
      <view class="block-title">交付信息</view>
      <view wx:if="{{order.shipping_address}}" class="kv"><text>收货地址</text><view>{{order.shipping_address.name}} {{order.shipping_address.phone}}<view class="muted">{{order.shipping_address.address}}</view></view></view>
      <view wx:if="{{order.delivery}}" class="kv"><text>交付方式</text><view>{{order.delivery.delivery_type_text}}<view class="muted">{{order.delivery.location_text}}</view></view></view>
      <view wx:if="{{order.delivery && order.delivery.delivery_note}}" class="kv"><text>交付说明</text><view>{{order.delivery.delivery_note}}</view></view>
      <view wx:if="{{!order.shipping_address && !order.delivery}}" class="muted">暂无交付信息</view>
    </view>

    <view class="panel">
      <view class="block-title">支付与售后</view>
      <view class="kv"><text>资金状态</text><view>{{fundText}}</view></view>
      <view class="kv"><text>当前状态</text><view>{{order.status_text}}</view></view>
      <view wx:if="{{order.refund}}" class="kv"><text>售后状态</text><view>{{order.refund.status_text || '处理中'}}<view class="muted">{{order.refund.reason}}</view></view></view>
      <view wx:else class="kv"><text>售后状态</text><view>暂无售后</view></view>
    </view>

    <view wx:if="{{order.reviews.length}}" class="panel">
      <view class="block-title">交易评价</view>
      <view wx:for="{{order.reviews}}" wx:key="id" class="review-line" data-id="{{item.id}}" bindtap="viewReview">
        <text>{{item.reviewer_role === 'buyer' ? '买家' : '卖家'}}评价 · {{item.rating}} 星</text>
        <text>查看 ›</text>
      </view>
    </view>

    <view class="actions">
      <button wx:if="{{actionMap.pay}}" class="primary-btn" bindtap="pay">去付款</button>
      <button wx:if="{{actionMap.cancel_order}}" class="ghost-btn" bindtap="cancel">取消订单</button>
      <button wx:if="{{actionMap.contact_seller || actionMap.contact_buyer}}" class="ghost-btn" bindtap="contactCounterparty">{{order.contact_label}}</button>
      <button wx:if="{{actionMap.seller_cancel_and_refund}}" class="ghost-btn" bindtap="sellerCancel">取消并退款</button>
      <button wx:if="{{actionMap.seller_deliver}}" class="primary-btn" bindtap="sellerDeliver">填写交付</button>
      <button wx:if="{{actionMap.confirm_receive}}" class="primary-btn" bindtap="confirmReceipt">确认收货</button>
      <button wx:if="{{actionMap.reject_receive}}" class="ghost-btn" bindtap="rejectReceive">拒绝收货</button>
      <button wx:if="{{actionMap.create_review}}" class="ghost-btn" bindtap="review">评价</button>
      <button wx:if="{{actionMap.apply_refund || actionMap.apply_after_sale}}" class="ghost-btn" bindtap="applyRefund">申请售后</button>
      <button wx:if="{{actionMap.apply_appeal}}" class="ghost-btn" bindtap="applyAppeal">平台介入</button>
      <button wx:if="{{actionMap.view_refund || actionMap.view_refund_result}}" class="ghost-btn" bindtap="viewRefund">查看售后</button>
    </view>
  </view>
  <view wx:else class="panel muted">正在加载订单...</view>
</view>
