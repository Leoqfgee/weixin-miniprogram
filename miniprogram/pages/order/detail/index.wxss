.steps {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 24rpx;
}

.step {
  flex: 1;
  padding: 10rpx 6rpx;
  color: #8a94a3;
  background: #f7f4ee;
  border-radius: 8rpx;
  font-size: 21rpx;
  text-align: center;
}

.step.active {
  color: #ffffff;
  background: #1f7a68;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
}

.fund {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  color: #8a4b14;
  background: #fff3df;
  border-radius: 8rpx;
  font-size: 25rpx;
}

.amount {
  margin-top: 24rpx;
  color: #d64545;
  font-size: 42rpx;
  font-weight: 700;
}

.item {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
}

.product-line {
  display: flex;
  gap: 18rpx;
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  background: #edf1f5;
}

.product-info {
  min-width: 0;
  flex: 1;
}

.info-block {
  margin-top: 22rpx;
  padding: 20rpx;
  background: #f8faf8;
  border-radius: 8rpx;
}

.block-title {
  margin-bottom: 10rpx;
  color: #17202a;
  font-weight: 800;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 14rpx;
}

.image-grid image {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  background: #edf1f5;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
}

.actions button {
  width: 210rpx;
  font-size: 26rpx;
}
.review-line{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;border-bottom:1rpx solid #e7ecef}.review-line:last-child{border-bottom:0}
