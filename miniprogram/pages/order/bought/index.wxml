<view class="page order-list-page">
  <scroll-view scroll-x class="tabs"><view class="tabs-inner"><view wx:for="{{statusOptions}}" wx:key="value" class="tab {{index === statusIndex ? 'active' : ''}}" data-index="{{index}}" bindtap="selectStatus">{{item.label}}</view></view></scroll-view>
  <view wx:if="{{orders.length}}" class="order-list">
    <view wx:for="{{orders}}" wx:key="id" class="panel order-card">
      <view class="card-head"><text>{{item.display_status}}</text><text>{{item.display_time}}</text></view>
      <view class="item-main" bindtap="goDetail" data-id="{{item.id}}">
        <image wx:if="{{item.snapshot.cover_image}}" class="thumb" src="{{item.snapshot.cover_image}}" mode="aspectFill"></image><view wx:else class="thumb placeholder">商品</view>
        <view class="info"><view class="title small">{{item.display_title}}</view><view class="price">{{item.display_amount}}</view><view class="party">{{item.counterparty_label}}?{{item.counterparty_name}}</view></view>
      </view>
      <view class="actions"><button wx:if="{{item.action_key === 'pay'}}" class="primary-btn" data-id="{{item.id}}" bindtap="pay">去付款</button><button wx:if="{{item.action_key === 'contact_seller'}}" class="ghost-btn" data-id="{{item.id}}" bindtap="goDetail">联系卖家</button><button wx:if="{{item.action_key === 'confirm'}}" class="primary-btn" data-id="{{item.id}}" bindtap="confirmReceive">确认收货</button><button wx:if="{{item.action_key === 'refund'}}" class="ghost-btn" bindtap="applyAfterSale" data-id="{{item.id}}" data-amount="{{item.total_amount}}">查看售后</button><button wx:if="{{item.action_key === 'detail'}}" class="ghost-btn" data-id="{{item.id}}" bindtap="goDetail">查看详情</button></view>
    </view>
  </view>
  <empty-state wx:else title="暂无买到的订单"></empty-state>
</view>
