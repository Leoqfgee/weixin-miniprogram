.tabs {
  margin: -4rpx 0 22rpx;
  white-space: nowrap;
}

.tabs-inner {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx;
}

.tab {
  padding: 16rpx 22rpx;
  color: #687380;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(31, 41, 51, 0.05);
}

.tab.active {
  color: #16a45a;
  background: #eaf8ef;
  font-weight: 900;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  border-radius: 24rpx;
}

.item-main {
  display: flex;
  gap: 20rpx;
}

.thumb {
  width: 146rpx;
  height: 146rpx;
  border-radius: 18rpx;
  flex: none;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #20c767, #0f9f55);
  font-weight: 900;
}

.info {
  flex: 1;
  min-width: 0;
}

.info .muted {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.actions button {
  flex: 1;
  min-width: 180rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 24rpx;
}

.party {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 8rpx 0;
  color: #586474;
  font-size: 24rpx;
}

.party image {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
}
