.order-list-page { padding: 20rpx 22rpx 120rpx; background: #f5f8f6; }
.tabs { position: sticky; top: 0; z-index: 35; margin: -20rpx -22rpx 20rpx; padding: 18rpx 22rpx 10rpx; white-space: nowrap; background: rgba(245,248,246,.98); backdrop-filter: blur(12rpx); }
.tabs-inner { display: inline-flex; gap: 14rpx; padding: 2rpx 2rpx 8rpx; }
.tab { height: 58rpx; line-height: 58rpx; padding: 0 24rpx; color: #687380; background: #fff; border-radius: 999rpx; box-shadow: 0 8rpx 20rpx rgba(31,41,51,.05); font-size: 24rpx; }
.tab.active { color: #fff; background: #16b86b; font-weight: 900; }
.order-list { display: flex; flex-direction: column; gap: 18rpx; }
.order-card { padding: 22rpx; border-radius: 22rpx; }
.card-head { display: flex; justify-content: space-between; align-items: center; gap: 16rpx; margin-bottom: 18rpx; color: #8b96a3; font-size: 23rpx; }
.card-head text:first-child { padding: 6rpx 14rpx; color: #0f9f5b; background: #eaf8f0; border-radius: 999rpx; font-weight: 800; }
.item-main { display: flex; gap: 18rpx; }
.thumb { width: 144rpx; height: 144rpx; flex: none; border-radius: 16rpx; background: #edf3ee; }
.placeholder { display: flex; align-items: center; justify-content: center; color: #fff; background: linear-gradient(135deg,#19c873,#0f9f5b); font-weight: 900; }
.info { flex: 1; min-width: 0; }
.title.small { display: -webkit-box; color: #17212b; font-size: 28rpx; line-height: 1.35; font-weight: 900; overflow: hidden; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.price { margin-top: 10rpx; color: #10a65d; font-size: 30rpx; font-weight: 900; }
.party { margin-top: 10rpx; color: #5f6b77; font-size: 24rpx; }
.actions { display: flex; justify-content: flex-end; gap: 14rpx; margin-top: 20rpx; }
.actions button { min-width: 176rpx; height: 66rpx; line-height: 64rpx; margin: 0; border-radius: 999rpx; font-size: 24rpx; }
