.order-list-page{padding-bottom:118rpx}.tabs{margin:-4rpx 0 18rpx;white-space:nowrap}.tabs-inner{display:inline-flex;gap:14rpx;padding:4rpx}.tab{padding:14rpx 24rpx;color:#687380;background:#fff;border-radius:999rpx;box-shadow:0 8rpx 20rpx rgba(31,41,51,.05);font-size:25rpx}.tab.active{color:#fff;background:#16b85e;font-weight:900}.order-list{display:flex;flex-direction:column;gap:18rpx}.order-card{padding:22rpx;background:#fff;border:1rpx solid #edf1ed;border-radius:16rpx;box-shadow:0 8rpx 24rpx rgba(31,41,51,.05)}.card-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;color:#7a8491;font-size:23rpx}.card-head text:first-child{color:#16a45a;font-weight:900}.item-main{display:flex;gap:18rpx}.thumb{width:146rpx;height:146rpx;border-radius:14rpx;flex:none;background:#edf1f5}.placeholder{display:flex;align-items:center;justify-content:center;color:#fff;background:#16b85e;font-weight:900}.info{flex:1;min-width:0}.title{display:-webkit-box;color:#1f2933;font-size:28rpx;font-weight:900;line-height:1.35;overflow:hidden;text-overflow:ellipsis;-webkit-line-clamp:2;-webkit-box-orient:vertical}.party{margin-top:12rpx;color:#687380;font-size:24rpx}.price{margin-top:12rpx;color:#08a85d;font-size:30rpx;font-weight:900}.actions{display:flex;justify-content:flex-end;gap:14rpx;margin-top:18rpx}.actions button{width:168rpx;height:66rpx;line-height:66rpx;margin:0;font-size:24rpx}
