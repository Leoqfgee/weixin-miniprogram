.product-card,.delivery{margin-bottom:20rpx}.price{margin-top:14rpx;color:#e0522d;font-size:36rpx;font-weight:800}.segments{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin:22rpx 0}.segments view{padding:18rpx;text-align:center;background:#f2f4f6;border:1rpx solid transparent;border-radius:8rpx}.segments .active{color:#1f7a68;background:#eef8f5;border-color:#1f7a68}.delivery input,.address{padding:20rpx;background:#f5f7fa;border-radius:8rpx}.address .muted{margin-top:8rpx}.empty{color:#1f7a68}.manage{width:260rpx;margin:18rpx 0 0;font-size:24rpx}.action{margin-top:32rpx}
