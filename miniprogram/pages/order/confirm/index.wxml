<view class="page">
  <view class="panel">
    <view class="title">确认订单</view>
    <view wx:if="{{product}}">
      <view class="product">{{product.title}}</view>
      <view class="price">￥{{product.price}} × {{quantity}}</view>
      <view class="muted">应付金额由后端重新计算，前端金额仅展示</view>
    </view>
    <input value="{{meetLocation}}" bindinput="onLocationInput" placeholder="约定交付地点" />
    <button class="primary-btn action" bindtap="onCreateOrder">提交订单</button>
  </view>
</view>
