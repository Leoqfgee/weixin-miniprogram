<view class="page order-list-page"><scroll-view scroll-x class="tabs"><view class="tabs-inner"><view wx:for="{{statusOptions}}" wx:key="value" class="tab {{index === statusIndex ? 'active' : ''}}" data-index="{{index}}" bindtap="selectStatus">{{item.label}}</view></view></scroll-view><view wx:if="{{orders.length}}" class="order-list"><view wx:for="{{orders}}" wx:key="id" class="order-card"><view class="card-head"><text>{{item.status_text}}</text><text>{{item.created_text}}</text></view><view class="item-main" bindtap="goDetail" data-id="{{item.id}}"><image wx:if="{{item.snapshot.cover_image}}" class="thumb" src="{{item.snapshot.cover_image}}" mode="aspectFill"></image><view wx:else class="thumb placeholder">图</view><view class="info"><view class="title small">{{item.snapshot.title || '订单商品'}}</view><view class="party">买家：{{item.party_name}}</view><view class="price">{{item.price_text}}</view></view></view><view class="actions"><button wx:if="{{item.allowed_actions.can_seller_cancel_and_refund}}" class="ghost-btn danger" data-id="{{item.id}}" bindtap="sellerCancel">取消退款</button><button class="primary-btn" data-index="{{index}}" bindtap="primaryAction">{{item.action_text}}</button></view></view></view><empty-state wx:else title="暂无卖出的订单"></empty-state></view>
