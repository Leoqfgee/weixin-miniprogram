<view class="page">
  <view class="page-head">
    <view>
      <view class="title">收货地址</view>
      <view class="muted">下单配送时可直接选择</view>
    </view>
    <button class="primary-btn compact" bindtap="addAddress">新增</button>
  </view>

  <view wx:if="{{editing}}" class="panel form">
    <input value="{{form.name}}" data-field="name" bindinput="setField" placeholder="收货人姓名" />
    <input value="{{form.phone}}" data-field="phone" bindinput="setField" type="number" maxlength="11" placeholder="手机号" />
    <textarea value="{{form.address}}" data-field="address" bindinput="setField" placeholder="省市区和详细收货地址"></textarea>
    <label class="default-row"><switch checked="{{form.is_default}}" bindchange="toggleDefault" color="#1f7a68" />设为默认地址</label>
    <view class="actions">
      <button class="ghost-btn" bindtap="cancelEdit">取消</button>
      <button class="primary-btn" bindtap="saveAddress">保存</button>
    </view>
  </view>

  <view wx:if="{{addresses.length}}" class="list">
    <view wx:for="{{addresses}}" wx:key="id" class="panel address">
      <view class="address-head">
        <view class="text-strong">{{item.name}}　{{item.phone}}</view>
        <text wx:if="{{item.is_default}}" class="default-tag">默认</text>
      </view>
      <view class="muted address-text">{{item.address}}</view>
      <view class="actions">
        <button wx:if="{{!item.is_default}}" class="ghost-btn" data-id="{{item.id}}" bindtap="setDefault">设为默认</button>
        <button class="ghost-btn" data-index="{{index}}" bindtap="editAddress">编辑</button>
        <button class="ghost-btn danger" data-id="{{item.id}}" bindtap="removeAddress">删除</button>
      </view>
    </view>
  </view>
  <empty-state wx:elif="{{!editing}}" title="还没有收货地址"></empty-state>
</view>
