.tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tab {
  min-width: 0;
  padding: 16rpx 6rpx;
  text-align: center;
  color: #687380;
  background: #ffffff;
  border: 1rpx solid #e8ece8;
  border-radius: 999rpx;
  font-size: 23rpx;
}

.tab.active {
  color: #16a45a;
  background: #eaf8ef;
  border-color: #cfeedd;
  font-weight: 900;
}

.count {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
}

.cleanup-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  color: #8a5a15;
  background: #fff7e6;
  border-radius: 18rpx;
  font-size: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.favorite-card {
  background: #ffffff;
  border: 1rpx solid #e8ece8;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 51, 0.06);
}

.favorite-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 0 20rpx 20rpx;
}

.note {
  display: block;
  color: #687380;
  font-size: 24rpx;
}

.note.drop {
  color: #f04438;
  font-weight: 900;
}

.mini {
  flex: none;
  min-width: 150rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  font-size: 23rpx;
}
