.settings-page {
  padding-bottom: 48rpx;
}

.profile-panel,
.action-panel,
.danger-panel {
  margin-top: 24rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 22rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #edf1ed;
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #16a45a;
  background: #eaf8ef;
  font-size: 38rpx;
  font-weight: 900;
}

.user-main {
  flex: 1;
  min-width: 0;
}

.name {
  color: #17202a;
  font-size: 34rpx;
  font-weight: 900;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf1ed;
}

.settings-item:last-child {
  border-bottom: 0;
}

.item-title {
  color: #17202a;
  font-size: 30rpx;
  font-weight: 800;
}

.full {
  width: 100%;
  margin-top: 20rpx;
}

.danger-btn {
  height: 82rpx;
  line-height: 82rpx;
  color: #fff;
  background: #f04438;
  border-radius: 22rpx;
  font-size: 29rpx;
}

.danger-tip {
  margin-top: 16rpx;
  color: #8a6670;
  font-size: 24rpx;
  line-height: 1.6;
}
