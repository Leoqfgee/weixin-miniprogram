.product-card {
  display: flex;
  gap: 20rpx;
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e8ece8;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 51, 0.07);
}

.cover {
  position: relative;
  width: 214rpx;
  height: 172rpx;
  flex: none;
  border-radius: 18rpx;
  overflow: hidden;
}

.placeholder {
  background: linear-gradient(145deg, #dff6e8 0%, #8fe0ad 45%, #17a95b 100%);
}

.cover-text {
  position: absolute;
  left: 18rpx;
  bottom: 22rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
}

.cover-tag {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  padding: 6rpx 12rpx;
  color: #ffffff;
  background: rgba(31, 41, 51, 0.45);
  border-radius: 999rpx;
  font-size: 20rpx;
}

.info {
  flex: 1;
  min-width: 0;
}

.name {
  color: #1f2933;
  font-size: 30rpx;
  line-height: 1.32;
  font-weight: 900;
}

.desc {
  display: -webkit-box;
  margin-top: 8rpx;
  color: #7a8491;
  font-size: 23rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  padding: 5rpx 12rpx;
  color: #11924f;
  background: #eaf8ef;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 12rpx;
}

.seller {
  max-width: 170rpx;
  color: #7a8491;
  font-size: 22rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.price {
  color: #f04438;
  font-size: 36rpx;
  font-weight: 900;
}
