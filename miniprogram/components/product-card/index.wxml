<view class="product-card {{layout === 'grid' ? 'grid-card' : ''}}" bindtap="onTap">
  <view class="cover-box">
    <image wx:if="{{coverImage && !coverFailed}}" class="cover" src="{{coverImage}}" mode="aspectFill" binderror="onCoverError"></image>
    <view wx:else class="cover placeholder"><text>{{coverText}}</text></view>
  </view>
  <view class="info">
    <view class="name">{{displayTitle}}</view>
    <view class="price-row">
      <text class="price">{{displayPrice}}</text>
      <text class="stock">库存 {{stockText}}</text>
    </view>
    <view class="meta-row">
      <text>{{campusText}}</text>
      <text>{{categoryText}}</text>
    </view>
    <view class="bottom">
      <text class="seller">{{sellerText}}</text>
      <text class="views">浏览 {{viewText}}</text>
    </view>
  </view>
</view>
