<view class="product-card {{layout === 'grid' ? 'grid-card' : ''}}" bindtap="onTap">
  <image wx:if="{{coverImage && !coverFailed}}" class="cover" src="{{coverImage}}" mode="aspectFill" binderror="onCoverError"></image>
  <view wx:else class="cover placeholder">
    <view class="cover-text">{{coverText}}</view>
    <view class="cover-tag">{{conditionText}}</view>
  </view>
  <button class="favorite-btn {{product.is_favorited ? 'active' : ''}}" catchtap="toggleFavorite">{{product.is_favorited ? '♥' : '♡'}}</button>
  <view class="info">
    <view class="name">{{product.title || '未命名商品'}}</view>
    <view class="tags">
      <text class="tag">{{campusText}}</text>
      <text wx:if="{{product.category_name}}" class="tag">{{product.category_name}}</text>
      <text class="tag">库存 {{product.stock || 0}}</text>
    </view>
    <view class="bottom">
      <text class="price">¥{{product.price || '0.00'}}</text>
      <text class="seller">{{product.seller ? product.seller.nickname : '校内同学'}}</text>
    </view>
  </view>
</view>
