<view class="product-card {{layout === 'grid' ? 'grid-card' : ''}}" bindtap="onTap">
  <view class="cover-box">
    <image wx:if="{{coverImage && !coverFailed}}" class="cover" src="{{coverImage}}" mode="aspectFill" binderror="onCoverError"></image>
    <view wx:else class="cover placeholder"><view class="cover-text">{{coverText}}</view></view>
    <button class="favorite-btn {{product.is_favorited ? 'active' : ''}}" catchtap="toggleFavorite">{{product.is_favorited ? '♥' : '♡'}}</button>
    <view class="status-chip">{{statusText}}</view>
  </view>
  <view class="info">
    <view class="name">{{displayTitle}}</view>
    <view class="price">{{displayPrice}}</view>
    <view class="tags">
      <text class="tag">{{campusText}}</text>
      <text class="tag">{{categoryText}}</text>
      <text class="tag">库存 {{stockText}}</text>
    </view>
    <view class="bottom"><text class="seller">{{sellerText}}</text><text class="views">浏览 {{viewText}}</text></view>
  </view>
</view>
