page {
  background: #f6f3ee;
  color: #1f2933;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 40rpx;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #ebe2d6;
  border-radius: 8rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(80, 65, 47, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #17202a;
}

.muted {
  color: #77808b;
}

.primary-btn {
  background: #1f7a68;
  color: #ffffff;
  border-radius: 8rpx;
  border: 0;
}

.ghost-btn {
  background: #ffffff;
  color: #1f7a68;
  border: 1rpx solid #1f7a68;
  border-radius: 8rpx;
}

.text-strong {
  color: #17202a;
  font-weight: 700;
}

.price-text {
  color: #e0522d;
  font-weight: 800;
}
