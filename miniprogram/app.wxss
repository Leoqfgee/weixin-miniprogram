page {
  background: #f5f8f6;
  color: #202733;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 56rpx;
}

.section {
  margin-bottom: 24rpx;
}

.panel,
.soft-card {
  background: #ffffff;
  border: 1rpx solid #e6eee9;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 34rpx rgba(28, 49, 42, 0.07);
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1f2933;
  letter-spacing: 0;
}

.title.small,
.small-title {
  font-size: 30rpx;
}

.muted {
  color: #7a8491;
}

.text-strong {
  color: #1f2933;
  font-weight: 800;
}

.price,
.price-text {
  color: #f04438;
  font-weight: 900;
}

.primary-btn,
.ghost-btn,
.pill-btn {
  box-sizing: border-box;
  height: 76rpx;
  line-height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 14rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #22c77a 0%, #16a66a 100%);
  border: 0;
  box-shadow: 0 12rpx 24rpx rgba(23, 180, 100, 0.24);
}

.ghost-btn {
  color: #149261;
  background: #ffffff;
  border: 1rpx solid #18a873;
}

.ghost-btn.danger,
.danger {
  color: #f04438;
  border-color: #f04438;
}

.tag,
.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  color: #11924f;
  background: #eaf8ef;
  border-radius: 999rpx;
  font-size: 22rpx;
}

input,
textarea,
.picker {
  box-sizing: border-box;
  width: 100%;
  background: #fbfcfb;
  border: 1rpx solid #dfe8e2;
  border-radius: 12rpx;
  color: #1f2933;
}

input,
.picker {
  height: 82rpx;
  padding: 0 24rpx;
}

textarea {
  min-height: 190rpx;
  padding: 22rpx 24rpx;
  line-height: 1.55;
}

.section-title,
.section-head {
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 900;
}

.section-title::before,
.block-title::before {
  content: "";
  display: inline-block;
  width: 8rpx;
  height: 30rpx;
  margin-right: 12rpx;
  vertical-align: -5rpx;
  background: #18a873;
  border-radius: 999rpx;
}

.mini-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  color: #202733;
  font-size: 32rpx;
  font-weight: 900;
}

.mini-nav .back {
  position: absolute;
  left: 24rpx;
  color: #202733;
  font-size: 44rpx;
  font-weight: 300;
}

.green-page {
  background: linear-gradient(180deg, #18a873 0, #2ac184 148rpx, #f5f8f6 148rpx);
}

.bottom-actions,
.bottom-bar,
.composer {
  box-shadow: 0 -10rpx 28rpx rgba(31, 41, 51, 0.08);
}
